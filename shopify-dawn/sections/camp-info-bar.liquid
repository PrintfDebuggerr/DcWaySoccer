{%- comment -%}
  Horizontal info strip below the camp hero.
  Each block = a labeled fact (Age, Location, Dates, Spots left, Schedule type, etc.).
  Default preset wires the 4 most useful facts straight from product metafields.
{%- endcomment -%}

{%- liquid
  assign mf_age = product.metafields.dcway.age_range
  assign mf_date_label = product.metafields.dcway.date_range_label
  assign mf_location = product.metafields.dcway.location.value
  assign mf_kind = product.metafields.dcway.product_kind

  assign total_inventory = 0
  for variant in product.variants
    if variant.inventory_quantity > 0
      assign total_inventory = total_inventory | plus: variant.inventory_quantity
    endif
  endfor
-%}

<div class="dcway-camp-info-bar color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <ul class="dcway-camp-info-bar__list" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign label = block.settings.label
          assign value = ''
          case block.settings.source
            when 'age'
              assign value = mf_age
            when 'location'
              assign value = mf_location.name
            when 'dates'
              assign value = mf_date_label
            when 'spots_left'
              if total_inventory > 0
                assign value = total_inventory | append: ' spots'
              else
                assign value = 'Sold out'
              endif
            when 'kind'
              assign value = mf_kind
            when 'custom'
              assign value = block.settings.custom_value
          endcase
        -%}
        {%- if value != blank -%}
          <li class="dcway-camp-info-bar__item" {{ block.shopify_attributes }}>
            <span class="dcway-camp-info-bar__label dcway-uppercase">{{ label }}</span>
            <span class="dcway-camp-info-bar__value">{{ value }}</span>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-camp-info-bar {
    padding-block: 32px;
    background: var(--dcway-muted-bg);
  }
  #shopify-section-{{ section.id }} .dcway-camp-info-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-camp-info-bar__item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-info-bar__label {
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--dcway-orange);
    letter-spacing: 0.08em;
  }
  #shopify-section-{{ section.id }} .dcway-camp-info-bar__value {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.15;
    color: var(--dcway-dark);
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-camp-info-bar__list {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 20px;
      text-align: left;
    }
    #shopify-section-{{ section.id }} .dcway-camp-info-bar__item {
      align-items: flex-start;
      padding-inline: 24px;
      border-left: 2px solid var(--dcway-muted-bg-2);
    }
    #shopify-section-{{ section.id }} .dcway-camp-info-bar__item:first-child {
      padding-left: 0;
      border-left: none;
    }
    #shopify-section-{{ section.id }} .dcway-camp-info-bar__value {
      font-size: 1.625rem;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Camp info bar (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Age"
        },
        {
          "type": "select",
          "id": "source",
          "label": "Value source",
          "options": [
            { "value": "age", "label": "Age range" },
            { "value": "location", "label": "Location" },
            { "value": "dates", "label": "Date range" },
            { "value": "spots_left", "label": "Total spots left" },
            { "value": "kind", "label": "Product kind" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "age"
        },
        {
          "type": "text",
          "id": "custom_value",
          "label": "Custom value (only used if source is 'Custom text')"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Camp info bar (DC Way)",
      "blocks": [
        { "type": "fact", "settings": { "label": "Age", "source": "age" } },
        { "type": "fact", "settings": { "label": "Location", "source": "location" } },
        { "type": "fact", "settings": { "label": "Dates", "source": "dates" } },
        { "type": "fact", "settings": { "label": "Spots left", "source": "spots_left" } }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
