{%- comment -%}
  WP-faithful port of DC Way's "KICKSTART THE FUN!" home section.

  Layout (desktop):
    - Top row: large heading on the left, "View all >" link on the right.
    - Carousel of camp products; one slide visible at a time.
      Each slide is a 2-column grid (5fr left / 6fr right).
      Left column = decorative absolute-positioned soccer-ball watermark
      (top-left, behind the text) + product title + description + outline
      "SIGN UP" button + prev/next arrow controls.
      Right column = product featured image at 345px tall.
    - Mobile: image stacks above title/desc/button; arrows hide.

  Reference: 03-saved-html-pages/01-home-main/DC Way Soccer.html lines 2240-2520.
{%- endcomment -%}

{%- liquid
  assign source = section.settings.collection
  assign limit = section.settings.product_limit | default: 6
  assign view_all_text = section.settings.view_all_label | default: 'View all'
  assign cta_text = section.settings.cta_label | default: 'SIGN UP'
  assign ball_url = section.settings.ball_image | image_url: width: 600
  if ball_url == blank
    assign ball_url = 'https://cdn.shopify.com/s/files/1/0754/3773/6108/files/dcway-kickstart-ball.svg'
  endif
-%}

<div class="dcway-camp-spotlight color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <div class="dcway-camp-spotlight__head">
      <h2 class="dcway-camp-spotlight__heading dcway-uppercase">
        {%- if section.settings.heading_lead != blank -%}{{ section.settings.heading_lead }} {% endif -%}
        {%- if section.settings.heading_accent != blank -%}<span class="dcway-accent">{{ section.settings.heading_accent }}</span>{%- endif -%}
      </h2>
      {%- if section.settings.show_view_all and source.url != blank -%}
        <a class="dcway-camp-spotlight__viewall" href="{{ source.url }}">
          {{ view_all_text }}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    {%- if source != blank and source.products_count > 0 -%}
      <dcway-camp-spotlight class="dcway-camp-spotlight__shell" data-count="{{ source.products_count | at_most: limit }}">
        <ul class="dcway-camp-spotlight__track" role="list">
          {%- for product in source.products limit: limit -%}
            {%- liquid
              assign desc = product.metafields.dcway.card_description.value | default: product.description | strip_html
              assign desc = desc | strip_newlines | truncatewords: 55
            -%}
            <li class="dcway-camp-spotlight__slide" data-index="{{ forloop.index0 }}" aria-roledescription="slide" aria-label="{{ forloop.index }} of {{ source.products_count }}">
              <div class="dcway-camp-spotlight__copy">
                <img class="dcway-camp-spotlight__ball" src="{{ ball_url }}" alt="" aria-hidden="true" loading="lazy" width="148" height="150">
                <div class="dcway-camp-spotlight__text">
                  <h3 class="dcway-camp-spotlight__title dcway-uppercase">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  {%- if desc != blank -%}
                    <p class="dcway-camp-spotlight__desc">{{ desc }}</p>
                  {%- endif -%}
                  <div class="dcway-camp-spotlight__actions">
                    <a class="dcway-camp-spotlight__cta dcway-uppercase" href="{{ product.url }}">{{ cta_text }}</a>
                    {%- if source.products_count > 1 -%}
                      <div class="dcway-camp-spotlight__arrows" role="group" aria-label="Carousel controls">
                        <button type="button" class="dcway-camp-spotlight__arrow" data-dir="-1" aria-label="Previous camp">
                          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <path d="M7.0608 9L12.3108 3.7517L11.2501 2.6915L4.9395 9L11.2501 15.3081L12.3108 14.2474L7.0608 9Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
                          </svg>
                        </button>
                        <button type="button" class="dcway-camp-spotlight__arrow" data-dir="1" aria-label="Next camp">
                          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                            <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
                          </svg>
                        </button>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
              <div class="dcway-camp-spotlight__media">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 1200 | image_tag:
                    loading: 'lazy',
                    widths: '400,600,800,1000,1200',
                    sizes: '(min-width: 750px) 50vw, 100vw',
                    alt: product.featured_media.alt | default: product.title
                  }}
                {%- else -%}
                  <div class="dcway-camp-spotlight__placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </dcway-camp-spotlight>
    {%- else -%}
      <p class="dcway-camp-spotlight__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-camp-spotlight {
    padding-block: 64px;
  }
  #shopify-section-{{ section.id }} .dcway-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 32px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__heading {
    margin: 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 48px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0;
    color: #2c2c2c;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__heading .dcway-accent { color: var(--dcway-orange, #ff7200); }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__viewall {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #2c2c2c;
    text-decoration: none;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 600;
    font-size: 16px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__viewall:hover { color: var(--dcway-orange, #ff7200); }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__shell { display: block; }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__track::-webkit-scrollbar { display: none; }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__slide {
    flex: 0 0 100%;
    min-width: 100%;
    scroll-snap-align: start;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__copy {
    position: relative;
    padding-top: 24px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__ball {
    position: absolute;
    top: -10px;
    left: -20px;
    width: 148px;
    height: 150px;
    opacity: 0.95;
    pointer-events: none;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__text {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__title {
    margin: 0 0 16px;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 36px;
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--dcway-orange, #ff7200);
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__title a {
    color: inherit;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__title a:hover { text-decoration: underline; }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__desc {
    margin: 0 0 28px;
    color: #2c2c2c;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.55;
    font-weight: 400;
    max-width: 52ch;
  }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1;
    color: var(--dcway-orange, #ff7200);
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    padding: 12px 40px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__cta:hover,
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__cta:focus-visible {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__arrows {
    display: inline-flex;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__arrow {
    width: 44px;
    height: 44px;
    padding: 0;
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    color: var(--dcway-orange, #ff7200);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__arrow:hover {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: #ffffff;
    color: var(--dcway-orange, #ff7200);
  }

  #shopify-section-{{ section.id }} .dcway-camp-spotlight__media {
    width: 100%;
    height: 345px;
    overflow: hidden;
    background: #f2f2f2;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__media img,
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .dcway-camp-spotlight__empty {
    text-align: center;
    color: #888;
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__slide {
      grid-template-columns: 5fr 6fr;
      gap: 20px;
      align-items: start;
    }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__copy {
      padding: 70px 20px 0 100px;
    }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__ball {
      top: -10px;
      left: -20px;
      width: 148px;
      height: 150px;
    }
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__heading { font-size: 36px; }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__slide {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__copy {
      padding: 60px 0 0 60px;
    }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__ball {
      width: 110px;
      height: 112px;
      top: 0;
      left: -10px;
    }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__title { font-size: 28px; }
    #shopify-section-{{ section.id }} .dcway-camp-spotlight__media {
      height: 240px;
      order: -1;
    }
  }
{%- endstyle -%}

<script>
  if (!window.customElements.get('dcway-camp-spotlight')) {
    class DcwayCampSpotlight extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('.dcway-camp-spotlight__track');
        this.count = parseInt(this.dataset.count, 10) || 0;
        this.current = 0;
        if (!this.track) return;
        this.addEventListener('click', (e) => {
          const btn = e.target.closest('.dcway-camp-spotlight__arrow');
          if (!btn) return;
          const dir = parseInt(btn.dataset.dir, 10);
          this.go(this.current + dir);
        });
        this.track.addEventListener('scroll', () => {
          const w = this.track.clientWidth;
          if (w === 0) return;
          this.current = Math.round(this.track.scrollLeft / w);
          this._updateArrows();
        }, { passive: true });
        this._updateArrows();
      }
      go(idx) {
        const target = Math.max(0, Math.min(this.count - 1, idx));
        this.track.scrollTo({ left: this.track.clientWidth * target, behavior: 'smooth' });
        this.current = target;
        this._updateArrows();
      }
      _updateArrows() {
        // Each slide carries its own arrow pair (one set rendered per slide so layout fits inside the copy column).
        // Update only the currently-visible slide's arrows.
        const slide = this.querySelectorAll('.dcway-camp-spotlight__slide')[this.current];
        if (!slide) return;
        const arrows = slide.querySelectorAll('.dcway-camp-spotlight__arrow');
        if (!arrows.length) return;
        arrows[0].disabled = this.current <= 0;
        arrows[1].disabled = this.current >= this.count - 1;
      }
    }
    window.customElements.define('dcway-camp-spotlight', DcwayCampSpotlight);
  }
</script>

{% schema %}
{
  "name": "Camp spotlight (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading_lead",
      "label": "Heading — lead word(s)",
      "default": "KICKSTART"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — orange-accent word(s)",
      "default": "THE FUN!"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Each product becomes one slide."
    },
    {
      "type": "image_picker",
      "id": "ball_image",
      "label": "Decorative ball image",
      "info": "Defaults to WP-style soccer ball watermark."
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum slides",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "SIGN UP"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Camps coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Camp spotlight (DC Way)"
    }
  ]
}
{% endschema %}
