{%- liquid
  assign members = shop.metaobjects.team_member.values | sort: 'position'
  assign count = members.size
-%}

<section class="dcway-team color-{{ section.settings.color_scheme }}" data-dcway-team data-count="{{ count }}">
  <div class="dcway-team__band">
    <h2 class="dcway-team__title">
      {%- if section.settings.heading_lead != blank -%}
        <span class="dcway-team__title-lead">{{ section.settings.heading_lead }}</span>
      {%- endif -%}
      {%- if section.settings.heading_accent != blank -%}
        <span class="dcway-team__title-accent">{{ section.settings.heading_accent }}</span>
      {%- endif -%}
    </h2>

    <div class="dcway-team__stage">
      {%- if count > 0 -%}
        <div class="dcway-team__viewport">
          {%- for m in members -%}
            <article
              class="dcway-team__slide"
              data-index="{{ forloop.index0 }}"
              data-state="hidden"
              aria-hidden="true"
            >
              <div class="dcway-team__photo-col">
                <div class="dcway-team__photo-wrap">
                  {%- if m.photo.value -%}
                    {{ m.photo.value
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        widths: '300, 500, 700, 900',
                        sizes: '(max-width: 749px) 80vw, 370px',
                        class: 'dcway-team__photo',
                        alt: m.name.value
                    }}
                  {%- else -%}
                    <div class="dcway-team__photo dcway-team__photo--placeholder">
                      {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
                <div class="dcway-team__info">
                  <div class="dcway-team__name">{{ m.name.value }}</div>
                  {%- if m.role.value != blank -%}
                    <div class="dcway-team__role">{{ m.role.value }}</div>
                  {%- endif -%}
                </div>
              </div>

              <div class="dcway-team__bio">
                {%- if m.bio.value != blank -%}
                  {%- assign paragraphs = m.bio.value | newline_to_br | split: '<br />' -%}
                  {%- for p in paragraphs -%}
                    {%- assign trimmed = p | strip -%}
                    {%- if trimmed != blank -%}
                      <p>{{ trimmed }}</p>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if count > 1 -%}
          <div class="dcway-team__controls">
            <button type="button" class="dcway-team__arrow" data-dcway-team-prev aria-label="Previous team member">
              <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12.5 4L7 10l5.5 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button type="button" class="dcway-team__arrow" data-dcway-team-next aria-label="Next team member">
              <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M7.5 4l5.5 6-5.5 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="dcway-team__empty">{{ section.settings.empty_state_text | escape }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.currentScript.previousElementSibling;
    if (!root || !root.matches('[data-dcway-team]')) return;
    var slides = Array.prototype.slice.call(root.querySelectorAll('.dcway-team__slide'));
    var count = slides.length;
    if (count === 0) return;

    var current = 0;

    function update(next) {
      next = ((next % count) + count) % count;
      var prevIdx = (next - 1 + count) % count;
      var nextIdx = (next + 1) % count;

      slides.forEach(function (s, i) {
        var state = 'hidden';
        if (i === next) state = 'active';
        else if (count > 1 && i === nextIdx) state = 'next';
        else if (count > 2 && i === prevIdx) state = 'prev';
        s.setAttribute('data-state', state);
        s.setAttribute('aria-hidden', state === 'active' ? 'false' : 'true');
      });
      current = next;
    }

    var prevBtn = root.querySelector('[data-dcway-team-prev]');
    var nextBtn = root.querySelector('[data-dcway-team-next]');
    if (prevBtn) prevBtn.addEventListener('click', function () { update(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { update(current + 1); });
    update(0);
  })();
</script>

<style>
  /* ─────────────────────────────────────────────────────────────
     WP-faithful rebuild of "OUR TEAM" section.
     Structure: white outer band (top/bottom) + inner orange/dark
     gradient band that hosts the slider.
     Geometry mirrors WP: 1430px reference, orange ~33% / dark ~67%.
     ───────────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .dcway-team {
    background: #ffffff;
    padding: 50px 0;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .dcway-team__band {
    position: relative;
    /* WP uses the source asset itself with background-size:cover so the
       orange/dark ratio scales with viewport. Falls back to a linear gradient. */
    background-color: #2C2C2C;
    background-image: url('{{ "dcway-team-bg.png" | asset_url }}');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: 0% 50%;
    min-height: 820px;
    overflow: hidden;
    isolation: isolate;
  }

  /* OUR TEAM heading: 60px Barlow Condensed weight 600, OUR dark / TEAM white.
     Positioned so OUR lands on the orange band and TEAM crosses into the dark.
     The bg image (1920×785) with background-size:cover puts the orange/dark
     edge near 34% of viewport on wide screens, so heading sits a bit right of
     centre of orange. */
  #shopify-section-{{ section.id }} .dcway-team__title {
    position: absolute;
    top: 10px;
    left: 22%;
    margin: 0;
    z-index: 3;
    font-family: 'Barlow Condensed', var(--font-heading-family), 'Oswald', sans-serif;
    font-weight: 600;
    font-size: 60px;
    line-height: 60px;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .dcway-team__title-lead { color: #2C2C2C; }
  #shopify-section-{{ section.id }} .dcway-team__title-accent { color: #ffffff; margin-left: 0.18em; }

  /* Stage is the positioning context for slides. */
  #shopify-section-{{ section.id }} .dcway-team__stage {
    position: relative;
    height: 820px;
  }
  #shopify-section-{{ section.id }} .dcway-team__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Slide base — absolutely placed, transitions on left/width. */
  #shopify-section-{{ section.id }} .dcway-team__slide {
    position: absolute;
    top: 0;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.45s ease,
      left 0.55s cubic-bezier(.22,.61,.36,1),
      transform 0.55s cubic-bezier(.22,.61,.36,1),
      visibility 0s linear 0.55s;
  }

  /* PREV slide (left peek): photo 300×375 on the orange panel. */
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="prev"] {
    left: 1%;
    top: 180px;
    opacity: 1;
    visibility: visible;
    z-index: 2;
    transition:
      opacity 0.45s ease,
      left 0.55s cubic-bezier(.22,.61,.36,1),
      transform 0.55s cubic-bezier(.22,.61,.36,1),
      visibility 0s;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="prev"] .dcway-team__photo {
    width: 300px;
    height: 375px;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="prev"] .dcway-team__info { width: 300px; }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="prev"] .dcway-team__bio { display: none; }

  /* ACTIVE slide (center): photo 370×450 + 530px bio panel; spans across boundary. */
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] {
    left: 34.3%;
    top: 120px;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 4;
    transition:
      opacity 0.45s ease,
      left 0.55s cubic-bezier(.22,.61,.36,1),
      transform 0.55s cubic-bezier(.22,.61,.36,1),
      visibility 0s;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] .dcway-team__photo {
    width: 370px;
    height: 450px;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] .dcway-team__info { width: 370px; }

  /* NEXT slide (right peek): photo 300×375 mostly off right edge — only ~80px of photo visible. */
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="next"] {
    left: calc(100% - 80px);
    top: 180px;
    opacity: 1;
    visibility: visible;
    z-index: 2;
    transition:
      opacity 0.45s ease,
      left 0.55s cubic-bezier(.22,.61,.36,1),
      transform 0.55s cubic-bezier(.22,.61,.36,1),
      visibility 0s;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="next"] .dcway-team__photo {
    width: 300px;
    height: 375px;
  }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="next"] .dcway-team__info { width: 300px; }
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="next"] .dcway-team__bio { display: none; }

  /* HIDDEN slides off-stage. */
  #shopify-section-{{ section.id }} .dcway-team__slide[data-state="hidden"] {
    left: -50%;
    top: 180px;
    opacity: 0;
    pointer-events: none;
  }

  /* Photo column. */
  #shopify-section-{{ section.id }} .dcway-team__photo-col {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  #shopify-section-{{ section.id }} .dcway-team__photo-wrap {
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .dcway-team__photo {
    object-fit: cover;
    display: block;
    background: rgba(255,255,255,0.05);
    transition: width 0.55s cubic-bezier(.22,.61,.36,1), height 0.55s cubic-bezier(.22,.61,.36,1);
  }
  #shopify-section-{{ section.id }} .dcway-team__photo--placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Name/role. */
  #shopify-section-{{ section.id }} .dcway-team__info { padding-top: 2px; }
  #shopify-section-{{ section.id }} .dcway-team__name {
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 4px;
    text-transform: none;
  }
  #shopify-section-{{ section.id }} .dcway-team__role {
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 500;
    font-size: 26px;
    line-height: 1.2;
    color: #fff;
  }

  /* Bio. */
  #shopify-section-{{ section.id }} .dcway-team__bio {
    width: 530px;
    max-width: 530px;
    padding: 0 20px;
    font-family: Arial, sans-serif;
    font-size: 18px;
    line-height: 1.33;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .dcway-team__bio p { margin: 0 0 12px; }
  #shopify-section-{{ section.id }} .dcway-team__bio p:last-child { margin-bottom: 0; }

  /* Arrows: 44×44 orange squares, bottom-left under the active photo column.
     Sit clear of the name/role text which can wrap to 2 lines on long names. */
  #shopify-section-{{ section.id }} .dcway-team__controls {
    position: absolute;
    bottom: 28px;
    left: 40%;
    display: flex;
    gap: 4px;
    z-index: 5;
  }
  #shopify-section-{{ section.id }} .dcway-team__arrow {
    width: 44px;
    height: 44px;
    background: #FF7200;
    border: 0;
    border-radius: 0;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  #shopify-section-{{ section.id }} .dcway-team__arrow:hover { background: #ff8a26; }
  #shopify-section-{{ section.id }} .dcway-team__arrow:active { transform: scale(0.95); }
  #shopify-section-{{ section.id }} .dcway-team__arrow svg { width: 18px; height: 18px; }

  #shopify-section-{{ section.id }} .dcway-team__empty {
    padding: 80px 40px;
    text-align: center;
    color: rgba(255,255,255,0.7);
  }

  /* ───────── TABLET (< 990px) ───────── */
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .dcway-team {
      padding: 30px 0;
    }
    #shopify-section-{{ section.id }} .dcway-team__band {
      background: linear-gradient(
        to bottom,
        #FF7200 0,
        #FF7200 clamp(180px, 22vw, 240px),
        #2A2A2A clamp(180px, 22vw, 240px),
        #2A2A2A 100%
      );
      min-height: auto;
    }
    #shopify-section-{{ section.id }} .dcway-team__title {
      position: relative;
      top: auto;
      left: auto;
      padding: clamp(28px, 4vw, 48px) clamp(24px, 4vw, 48px) clamp(20px, 3vw, 32px);
      font-size: clamp(48px, 7vw, 72px);
      line-height: 1;
    }
    #shopify-section-{{ section.id }} .dcway-team__stage {
      height: auto;
      padding: 0 clamp(24px, 4vw, 48px) clamp(80px, 10vw, 120px);
    }
    #shopify-section-{{ section.id }} .dcway-team__viewport {
      height: auto;
      min-height: 600px;
    }
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="prev"],
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="next"] {
      display: none;
    }
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] {
      position: relative;
      left: auto;
      top: auto;
      flex-direction: row;
      gap: 24px;
    }
    #shopify-section-{{ section.id }} .dcway-team__bio {
      width: auto;
      max-width: none;
      flex: 1 1 auto;
      padding: 0;
    }
    #shopify-section-{{ section.id }} .dcway-team__controls {
      left: clamp(24px, 4vw, 48px);
      bottom: clamp(28px, 4vw, 40px);
    }
  }

  /* ───────── MOBILE (< 750px) ───────── */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] {
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] .dcway-team__photo {
      width: 280px;
      height: 350px;
    }
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] .dcway-team__info {
      width: auto;
    }
    #shopify-section-{{ section.id }} .dcway-team__name { font-size: 32px; }
    #shopify-section-{{ section.id }} .dcway-team__role { font-size: 20px; }
    #shopify-section-{{ section.id }} .dcway-team__bio {
      font-size: 15px;
      line-height: 1.5;
    }
    #shopify-section-{{ section.id }} .dcway-team__viewport {
      min-height: auto;
      padding-bottom: 24px;
    }
    #shopify-section-{{ section.id }} .dcway-team__controls {
      position: relative;
      left: auto;
      bottom: auto;
      margin-top: 16px;
      padding: 0 clamp(24px, 4vw, 48px);
    }
  }

  /* Respect reduced motion. */
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .dcway-team__slide,
    #shopify-section-{{ section.id }} .dcway-team__photo {
      transition: opacity 0.2s linear, visibility 0s linear 0.2s;
    }
    #shopify-section-{{ section.id }} .dcway-team__slide[data-state="active"] {
      transition: opacity 0.2s linear, visibility 0s;
    }
  }
</style>

{% schema %}
{
  "name": "Our Team (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading_lead",
      "label": "Heading (left)",
      "default": "OUR"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading (right)",
      "default": "TEAM"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Team bios coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Our Team (DC Way)"
    }
  ]
}
{% endschema %}
