{%- liquid
  assign source = section.settings.collection
  assign limit = section.settings.product_limit | default: 12
  assign cols = section.settings.columns_desktop | default: 3
  assign cta = section.settings.cta_label | default: 'View program'
  assign per_page = section.settings.per_page | default: 9
  assign use_pagination = section.settings.enable_pagination
-%}

<div class="dcway-programs-grid color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="dcway-programs-grid__heading dcway-uppercase">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <div class="dcway-programs-grid__intro rte">{{ section.settings.intro_text }}</div>
    {%- endif -%}

    {%- if source != blank and source.products_count > 0 -%}
      {%- if use_pagination -%}
        {%- paginate source.products by per_page -%}
          <ul class="dcway-programs-grid__grid" role="list" data-cols="{{ cols }}">
            {%- for product in source.products -%}
              <li class="dcway-programs-grid__item">
                {%- render 'card-camp',
                  product: product,
                  cta_label: cta,
                  show_price: section.settings.show_price,
                  show_meta: section.settings.show_meta,
                  style: section.settings.card_style
                -%}
              </li>
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            <nav class="dcway-programs-grid__pagination" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a class="dcway-programs-grid__page-link dcway-programs-grid__page-link--prev" href="{{ paginate.previous.url }}" aria-label="Previous page">
                  <span aria-hidden="true">&lsaquo;</span>
                </a>
              {%- else -%}
                <span class="dcway-programs-grid__page-link dcway-programs-grid__page-link--disabled" aria-hidden="true">&lsaquo;</span>
              {%- endif -%}

              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a class="dcway-programs-grid__page-link" href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="dcway-programs-grid__page-link dcway-programs-grid__page-link--current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="dcway-programs-grid__page-link dcway-programs-grid__page-link--disabled">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if paginate.next -%}
                <a class="dcway-programs-grid__page-link dcway-programs-grid__page-link--next" href="{{ paginate.next.url }}" aria-label="Next page">
                  <span aria-hidden="true">&rsaquo;</span>
                </a>
              {%- else -%}
                <span class="dcway-programs-grid__page-link dcway-programs-grid__page-link--disabled" aria-hidden="true">&rsaquo;</span>
              {%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <ul class="dcway-programs-grid__grid" role="list" data-cols="{{ cols }}">
          {%- for product in source.products limit: limit -%}
            <li class="dcway-programs-grid__item">
              {%- render 'card-camp',
                product: product,
                cta_label: cta,
                show_price: section.settings.show_price,
                show_meta: section.settings.show_meta,
                style: section.settings.card_style
              -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.show_view_all and source.url != blank -%}
        <div class="dcway-programs-grid__more">
          <a class="button dcway-uppercase" href="{{ source.url }}">{{ section.settings.view_all_label | default: 'View all' }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="dcway-programs-grid__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-programs-grid {
    padding-block: 48px;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__heading {
    margin: 0 0 24px;
    font-family: "Barlow Condensed", Tahoma, Arial, sans-serif;
    font-size: 72px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    text-align: left;
    color: var(--dcway-text, #212121);
  }
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .dcway-programs-grid__heading {
      font-size: 50px;
    }
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__intro {
    margin: 0 auto 32px;
    max-width: 720px;
    text-align: center;
    color: var(--dcway-muted);
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__item {
    display: flex;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__empty {
    text-align: center;
    color: var(--dcway-muted);
    font-style: italic;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__more {
    margin-top: 32px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-top: 36px;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    font-family: "Barlow Condensed", Tahoma, Arial, sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--dcway-orange, #ff7200);
    border: 1px solid transparent;
    text-decoration: none;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link:hover {
    border-color: var(--dcway-orange, #ff7200);
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link--current {
    color: var(--dcway-text, #212121);
    border-color: var(--dcway-orange, #ff7200);
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link--disabled {
    color: var(--dcway-muted, #999);
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link--prev,
  #shopify-section-{{ section.id }} .dcway-programs-grid__page-link--next {
    font-size: 24px;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-programs-grid__grid[data-cols='2'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-programs-grid__grid[data-cols='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-programs-grid__grid[data-cols='4'] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Programs grid (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Programs"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text",
      "default": "<p>Year-round training, leagues, and clinics.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Pick a programs collection (e.g. Programs, Leagues, Clinics, Private Lessons)."
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum cards (no pagination)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "enable_pagination",
      "label": "Enable pagination",
      "default": false
    },
    {
      "type": "range",
      "id": "per_page",
      "label": "Cards per page",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 9
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card CTA label",
      "default": "View program"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "options": [
        { "value": "default", "label": "Default (image + meta + price)" },
        { "value": "program", "label": "Program (WP-style)" }
      ],
      "default": "program"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show meta line (age · season · location)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": false
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all programs"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Programs coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Programs grid (DC Way)",
      "settings": {
        "heading": "Programs"
      }
    }
  ]
}
{% endschema %}
