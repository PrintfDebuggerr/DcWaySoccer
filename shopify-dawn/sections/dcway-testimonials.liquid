{%- comment -%}
  WP-faithful port of DC Way's "TESTIMONIALS" home section.

  Layout:
    - Top: heading "TESTIMONIALS" (Barlow Condensed 48px uppercase) on left
      with "View all >" link to its right. A decorative "ball motion"
      SVG (group_9) is absolute-positioned next to the heading, drifting
      upward-right (matches WP `.elementor-element-b11110c` absolute image
      at width 319px / height 149px).
    - Below: a horizontal-scroll carousel of speech-bubble testimonial cards.
      Each card:
        - 2px solid orange border, white fill, padding 45px/30px/30px/30px.
        - Absolute-positioned large open-quote SVG at the top-left
          (~80px wide, overlapping the top edge of the card).
        - Absolute-positioned small "speech tail" PNG at the bottom-left
          (28x33), so the card reads as a speech bubble.
        - Quote text: Montserrat 18px italic weight 700, line-height 1.3em.
        - Author line: Nunito Sans 16px weight 400, dark.
    - Prev/next arrow buttons centered below the carousel.

  Reference: 03-saved-html-pages/01-home-main/DC Way Soccer.html lines 4606-4830.
{%- endcomment -%}

{%- liquid
  assign entries = shop.metaobjects.testimonial.values
  assign limit = section.settings.limit | default: 12
  assign view_all_text = section.settings.view_all_label | default: 'View all'
-%}

<div class="dcway-testimonials color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <header class="dcway-testimonials__head">
      <h2 class="dcway-testimonials__heading dcway-uppercase">{{ section.settings.heading }}</h2>
      {%- if section.settings.show_view_all and section.settings.view_all_link != blank -%}
        <a class="dcway-testimonials__viewall" href="{{ section.settings.view_all_link }}">
          {{ view_all_text }}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
          </svg>
        </a>
      {%- endif -%}
      <img class="dcway-testimonials__ball" src="{{ 'dcway-ball-motion.svg' | asset_url }}" alt="" aria-hidden="true" width="319" height="149" loading="lazy">
    </header>

    {%- if entries.size > 0 -%}
      <dcway-testimonials class="dcway-testimonials__shell" data-count="{{ entries.size | at_most: limit }}">
        <ul class="dcway-testimonials__track" role="list">
          {%- for entry in entries limit: limit -%}
            {%- liquid
              assign quote_raw = entry.quote.value | default: entry.quote
              assign author = entry.author.value | default: entry.author
            -%}
            <li class="dcway-testimonials__slide" aria-roledescription="slide" aria-label="{{ forloop.index }} of {{ entries.size }}">
              <figure class="dcway-testimonials__card">
                <img class="dcway-testimonials__quote-mark" src="{{ 'dcway-quote-mark.svg' | asset_url }}" alt="" aria-hidden="true" loading="lazy">
                <img class="dcway-testimonials__tail" src="{{ 'dcway-quote-tail.png' | asset_url }}" alt="" aria-hidden="true" width="28" height="33" loading="lazy">
                <blockquote class="dcway-testimonials__quote">
                  <p>{{ quote_raw }}</p>
                </blockquote>
                {%- if author != blank -%}
                  <figcaption class="dcway-testimonials__author">{{ author }}</figcaption>
                {%- endif -%}
              </figure>
            </li>
          {%- endfor -%}
        </ul>

        {%- if entries.size > 1 -%}
          <div class="dcway-testimonials__arrows" role="group" aria-label="Carousel controls">
            <button type="button" class="dcway-testimonials__arrow" data-dir="-1" aria-label="Previous testimonial">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M7.0608 9L12.3108 3.7517L11.2501 2.6915L4.9395 9L11.2501 15.3081L12.3108 14.2474L7.0608 9Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
              </svg>
            </button>
            <button type="button" class="dcway-testimonials__arrow" data-dir="1" aria-label="Next testimonial">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </dcway-testimonials>
    {%- else -%}
      <p class="dcway-testimonials__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-testimonials {
    padding-block: 64px;
  }
  #shopify-section-{{ section.id }} .dcway-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .dcway-testimonials__head {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 56px;
    padding-right: 320px;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__heading {
    margin: 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 48px;
    line-height: 1;
    font-weight: 700;
    color: #2c2c2c;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__viewall {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #2c2c2c;
    text-decoration: none;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 600;
    font-size: 16px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__viewall:hover { color: var(--dcway-orange, #ff7200); }
  #shopify-section-{{ section.id }} .dcway-testimonials__ball {
    position: absolute;
    right: 0;
    top: -10px;
    width: 280px;
    height: auto;
    pointer-events: none;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .dcway-testimonials__shell {
    display: block;
    position: relative;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__track {
    list-style: none;
    margin: 0;
    padding: 50px 8px 40px;
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__track::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .dcway-testimonials__slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    display: flex;
    justify-content: center;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__card {
    position: relative;
    width: 100%;
    max-width: 880px;
    min-height: 240px;
    margin: 0;
    padding: 50px 60px 50px 80px;
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__quote-mark {
    position: absolute;
    top: -38px;
    left: 42px;
    width: 80px;
    height: auto;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__tail {
    position: absolute;
    bottom: -33px;
    left: 110px;
    width: 28px;
    height: 33px;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__quote {
    margin: 0;
    color: #2c2c2c;
    font-family: 'Montserrat', 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 18px;
    font-weight: 700;
    font-style: italic;
    line-height: 1.4em;
    text-align: left;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__quote p { margin: 0; }
  #shopify-section-{{ section.id }} .dcway-testimonials__author {
    color: #2c2c2c;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .dcway-testimonials__arrows {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__arrow {
    width: 44px;
    height: 44px;
    padding: 0;
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    color: var(--dcway-orange, #ff7200);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__arrow:hover {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .dcway-testimonials__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: #ffffff;
    color: var(--dcway-orange, #ff7200);
  }

  #shopify-section-{{ section.id }} .dcway-testimonials__empty {
    text-align: center;
    color: #888;
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-testimonials__head {
      padding-right: 0;
      flex-wrap: wrap;
      gap: 8px;
    }
    #shopify-section-{{ section.id }} .dcway-testimonials__heading { font-size: 36px; }
    #shopify-section-{{ section.id }} .dcway-testimonials__ball {
      position: static;
      width: 200px;
      margin-top: 16px;
    }
    #shopify-section-{{ section.id }} .dcway-testimonials__card {
      padding: 45px 24px 35px;
    }
    #shopify-section-{{ section.id }} .dcway-testimonials__quote-mark {
      width: 60px;
      top: -28px;
      left: 20px;
    }
    #shopify-section-{{ section.id }} .dcway-testimonials__tail {
      left: 60px;
    }
    #shopify-section-{{ section.id }} .dcway-testimonials__quote { font-size: 16px; }
  }
{%- endstyle -%}

<script>
  if (!window.customElements.get('dcway-testimonials')) {
    class DcwayTestimonials extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('.dcway-testimonials__track');
        this.arrows = this.querySelectorAll('.dcway-testimonials__arrow');
        this.count = parseInt(this.dataset.count, 10) || 0;
        this.current = 0;
        if (!this.track) return;
        this.arrows.forEach((b) => {
          b.addEventListener('click', () => {
            const dir = parseInt(b.dataset.dir, 10);
            this.go(this.current + dir);
          });
        });
        this.track.addEventListener('scroll', () => {
          const w = this.track.clientWidth;
          if (w === 0) return;
          this.current = Math.round(this.track.scrollLeft / w);
          this._updateArrows();
        }, { passive: true });
        this._updateArrows();
      }
      go(idx) {
        const target = Math.max(0, Math.min(this.count - 1, idx));
        this.track.scrollTo({ left: this.track.clientWidth * target, behavior: 'smooth' });
        this.current = target;
        this._updateArrows();
      }
      _updateArrows() {
        if (!this.arrows.length) return;
        this.arrows[0].disabled = this.current <= 0;
        this.arrows[1].disabled = this.current >= this.count - 1;
      }
    }
    window.customElements.define('dcway-testimonials', DcwayTestimonials);
  }
</script>

{% schema %}
{
  "name": "Testimonials (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Testimonials"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Maximum testimonials",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "'View all' link"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Testimonials coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Testimonials (DC Way)"
    }
  ]
}
{% endschema %}
