{%- comment -%}
  Renders the camp's weekly themes from product.metafields.dcway.weeks
  (list of camp_week metaobjects). Each week → card with number, date, title,
  optional image and description.
{%- endcomment -%}

{%- liquid
  assign weeks = product.metafields.dcway.weeks.value
  assign cols = section.settings.columns_desktop | default: 3
-%}

<div class="dcway-camp-weeks color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="dcway-camp-weeks__heading dcway-uppercase">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="dcway-camp-weeks__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if weeks != blank and weeks.size > 0 -%}
      <ul class="dcway-camp-weeks__grid" role="list" data-cols="{{ cols }}">
        {%- for week in weeks -%}
          <li class="dcway-camp-weeks__item">
            <article class="dcway-camp-weeks__card">
              {%- if week.image != blank -%}
                <div class="dcway-camp-weeks__card-media">
                  {{ week.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: week.title, width: 350, height: 240 }}
                </div>
              {%- endif -%}
              <div class="dcway-camp-weeks__card-body">
                {%- if week.week_number != blank -%}
                  <span class="dcway-camp-weeks__card-num">Week {{ week.week_number }}</span>
                {%- endif -%}
                {%- if week.date_label != blank -%}
                  <p class="dcway-camp-weeks__card-date">{{ week.date_label }}</p>
                {%- endif -%}
                {%- if week.title != blank -%}
                  <h3 class="dcway-camp-weeks__card-title">{{ week.title }}</h3>
                {%- endif -%}
                {%- if week.description != blank -%}
                  <p class="dcway-camp-weeks__card-desc">{{ week.description }}</p>
                {%- endif -%}
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="dcway-camp-weeks__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-camp-weeks {
    padding-block: 56px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__heading {
    margin: 0 0 8px;
    font-size: 1.875rem;
    line-height: 1.1;
    font-weight: 700;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__sub {
    margin: 0 auto 32px;
    max-width: 640px;
    text-align: center;
    color: var(--dcway-muted);
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__item {
    display: flex;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    border: 1px solid var(--dcway-muted-bg);
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-media {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--dcway-muted-bg);
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-num {
    display: inline-block;
    align-self: flex-start;
    background: var(--dcway-orange);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-date {
    margin: 4px 0 0;
    font-size: 0.875rem;
    color: var(--dcway-muted);
    font-weight: 600;
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-title {
    margin: 2px 0 0;
    font-size: 1.125rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--dcway-dark);
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__card-desc {
    margin: 6px 0 0;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--dcway-text);
  }
  #shopify-section-{{ section.id }} .dcway-camp-weeks__empty {
    text-align: center;
    color: var(--dcway-muted);
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-camp-weeks__grid[data-cols='2'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-camp-weeks__grid[data-cols='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-camp-weeks__grid[data-cols='4'] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Camp weeks (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Weekly themes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Each week has its own theme — projects, games, and tournaments built around it."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Weekly schedule coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Camp weeks (DC Way)"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
