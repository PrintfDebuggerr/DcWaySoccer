{%- comment -%}
  WP-faithful port of dcway.com/camps/ archive landing.
  3-column grid of camp category cards: image / orange title / paragraph / outlined "LEARN MORE" button.
  Reference: 03-saved-html-pages/01-home-main/DC Way Soccer.html lines 2270-2610 (titles + descriptions)
             and 01-elementor-kit/wp-content/camps/camps.xml (content:encoded for the 3 day-camp rows).
{%- endcomment -%}

<div class="dcway-camps-landing color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    {%- if section.settings.heading != blank -%}
      <h1 class="dcway-camps-landing__heading dcway-uppercase">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="dcway-camps-landing__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign img = block.settings.image
            assign fallback = block.settings.image_fallback
          -%}
          <li class="dcway-camps-landing__card" {{ block.shopify_attributes }}>
            <div class="dcway-camps-landing__media">
              {%- if img != blank -%}
                {{ img | image_url: width: 900 | image_tag: loading: 'lazy', widths: '400,600,800,1000', sizes: '(min-width: 990px) 32vw, (min-width: 750px) 48vw, 100vw', alt: block.settings.title }}
              {%- elsif fallback != blank -%}
                <img src="{{ fallback | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="768" height="512">
              {%- else -%}
                <div class="dcway-camps-landing__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </div>
            {%- if block.settings.title != blank -%}
              <h2 class="dcway-camps-landing__title dcway-uppercase">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">{{ block.settings.title }}</a>
                {%- else -%}
                  {{ block.settings.title }}
                {%- endif -%}
              </h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="dcway-camps-landing__body rte">{{ block.settings.body }}</div>
            {%- endif -%}
            {%- if block.settings.link != blank and block.settings.button_label != blank -%}
              <a class="dcway-camps-landing__cta" href="{{ block.settings.link }}">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-camps-landing {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .dcway-container {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__heading {
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 800;
    line-height: 1;
    color: #2c2c2c;
    margin: 0 0 32px;
    letter-spacing: -0.01em;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 56px 32px;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__media {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f2f2f2;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__media img,
  #shopify-section-{{ section.id }} .dcway-camps-landing__placeholder svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__title {
    margin: 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-weight: 600;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--dcway-orange, #ff7200);
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__title a {
    color: inherit;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__title a:hover {
    text-decoration: underline;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__body {
    margin: 0;
    color: #2c2c2c;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__body p {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: auto;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
    color: var(--dcway-orange, #ff7200);
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    padding: 12px 36px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-camps-landing__cta:hover,
  #shopify-section-{{ section.id }} .dcway-camps-landing__cta:focus-visible {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .dcway-camps-landing__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 24px;
    }
  }
  @media (max-width: 599px) {
    #shopify-section-{{ section.id }} .dcway-camps-landing__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    #shopify-section-{{ section.id }} .dcway-camps-landing__heading {
      font-size: 44px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Camps landing grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CAMPS"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "camp_card",
      "name": "Camp card",
      "limit": 24,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_fallback",
          "label": "Image fallback (asset filename)",
          "info": "Used when no image is picked. Leave blank to show a placeholder."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Learn more"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Camps landing grid",
      "blocks": [
        { "type": "camp_card" },
        { "type": "camp_card" },
        { "type": "camp_card" }
      ]
    }
  ]
}
{% endschema %}
