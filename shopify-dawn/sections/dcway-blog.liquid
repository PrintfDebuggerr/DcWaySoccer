{%- comment -%}
  WP-faithful port of DC Way's "DC WAY BLOG" home section.

  Layout (desktop):
    - Top: heading "DC WAY <accent>BLOG</accent>" with "View all >" link
      directly beneath it. Left-aligned, no header-right content.
    - Body: 2-column grid.
        Left (4fr) = intro paragraph stacked above a large panda mascot.
        Right (8fr) = horizontal-scroll carousel of blog cards (2-up at
        desktop, 1-up on mobile). Prev/next arrow buttons absolute-positioned
        at the top-right of the carousel column (above the cards, matching
        WP's `.elementor-pagination { top: -80px; right: 0 }`).
    - Card: 270px featured image; Barlow Condensed 36px title (not uppercase,
      orange, weight 500); Nunito Sans excerpt (16px / 1.5em line-height);
      "LEARN MORE" outline button anchored to card bottom.
    - Mobile: body stacks (intro on top, carousel below); mascot scales down.

  Reference: 03-saved-html-pages/01-home-main/DC Way Soccer.html lines 3845-4170.
{%- endcomment -%}

{%- liquid
  assign blog_obj = blogs[section.settings.blog]
  assign limit = section.settings.post_limit | default: 6
  assign cta_text = section.settings.cta_label | default: 'LEARN MORE'
  assign view_all_text = section.settings.view_all_label | default: 'View all'
  assign mascot_url = section.settings.mascot_image | image_url: width: 800
  if mascot_url == blank
    assign mascot_url = 'https://cdn.shopify.com/s/files/1/0754/3773/6108/files/dcway-blog-mascot.png'
  endif
-%}

<div class="dcway-blog color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <header class="dcway-blog__header">
      <h2 class="dcway-blog__heading dcway-uppercase">
        {%- if section.settings.heading_lead != blank -%}{{ section.settings.heading_lead }} {% endif -%}
        {%- if section.settings.heading_accent != blank -%}<span class="dcway-accent">{{ section.settings.heading_accent }}</span>{%- endif -%}
      </h2>
      {%- if section.settings.show_view_all and blog_obj.url != blank -%}
        <a class="dcway-blog__viewall" href="{{ blog_obj.url }}">
          {{ view_all_text }}
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
          </svg>
        </a>
      {%- endif -%}
    </header>

    <div class="dcway-blog__body">
      <aside class="dcway-blog__intro-block">
        {%- if section.settings.intro != blank -%}
          <p class="dcway-blog__intro">{{ section.settings.intro }}</p>
        {%- endif -%}
        {%- if mascot_url != blank -%}
          <img class="dcway-blog__mascot" src="{{ mascot_url }}" alt="" aria-hidden="true" loading="lazy">
        {%- endif -%}
      </aside>

      {%- if blog_obj.articles_count > 0 -%}
        <dcway-blog class="dcway-blog__carousel" data-count="{{ blog_obj.articles_count | at_most: limit }}">
          {%- if blog_obj.articles_count > 2 -%}
            <div class="dcway-blog__arrows" role="group" aria-label="Carousel controls">
              <button type="button" class="dcway-blog__arrow" data-dir="-1" aria-label="Previous post">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M7.0608 9L12.3108 3.7517L11.2501 2.6915L4.9395 9L11.2501 15.3081L12.3108 14.2474L7.0608 9Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
                </svg>
              </button>
              <button type="button" class="dcway-blog__arrow" data-dir="1" aria-label="Next post">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
                </svg>
              </button>
            </div>
          {%- endif -%}

          <ul class="dcway-blog__track" role="list">
            {%- for article in blog_obj.articles limit: limit -%}
              {%- liquid
                assign excerpt = article.excerpt | default: article.content | strip_html
                assign excerpt = excerpt | strip_newlines | truncatewords: 38
              -%}
              <li class="dcway-blog__slide">
                <article class="dcway-blog__card">
                  <a class="dcway-blog__media" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
                    {%- if article.image -%}
                      {{ article.image | image_url: width: 900 | image_tag:
                        loading: 'lazy',
                        widths: '300,500,700,900',
                        sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                        alt: article.image.alt | default: article.title
                      }}
                    {%- else -%}
                      <div class="dcway-blog__placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </a>
                  <div class="dcway-blog__body-text">
                    <h3 class="dcway-blog__title">
                      <a href="{{ article.url }}">{{ article.title }}</a>
                    </h3>
                    {%- if excerpt != blank -%}
                      <p class="dcway-blog__excerpt">{{ excerpt }}</p>
                    {%- endif -%}
                  </div>
                  <div class="dcway-blog__cta-wrap">
                    <a class="dcway-blog__cta dcway-uppercase" href="{{ article.url }}">{{ cta_text }}</a>
                  </div>
                </article>
              </li>
            {%- endfor -%}
          </ul>
        </dcway-blog>
      {%- else -%}
        <p class="dcway-blog__empty">{{ section.settings.empty_state_text }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-blog {
    padding-block: 64px;
  }
  #shopify-section-{{ section.id }} .dcway-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .dcway-blog__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 32px;
  }
  #shopify-section-{{ section.id }} .dcway-blog__heading {
    margin: 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 48px;
    line-height: 1;
    font-weight: 700;
    color: #2c2c2c;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-blog__heading .dcway-accent { color: var(--dcway-orange, #ff7200); }
  #shopify-section-{{ section.id }} .dcway-blog__viewall {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #2c2c2c;
    text-decoration: none;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 600;
    font-size: 16px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .dcway-blog__viewall:hover { color: var(--dcway-orange, #ff7200); }

  #shopify-section-{{ section.id }} .dcway-blog__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .dcway-blog__intro-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-blog__intro {
    margin: 0;
    color: #2c2c2c;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .dcway-blog__mascot {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    margin: 12px 0 0;
  }

  #shopify-section-{{ section.id }} .dcway-blog__carousel {
    position: relative;
    display: block;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-blog__arrows {
    position: absolute;
    top: -64px;
    right: 0;
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .dcway-blog__arrow {
    width: 44px;
    height: 44px;
    padding: 0;
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    color: var(--dcway-orange, #ff7200);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-blog__arrow:hover {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .dcway-blog__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: #ffffff;
    color: var(--dcway-orange, #ff7200);
  }

  #shopify-section-{{ section.id }} .dcway-blog__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: stretch;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .dcway-blog__track::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .dcway-blog__slide {
    flex: 0 0 100%;
    align-self: stretch;
    scroll-snap-align: start;
    min-width: 0;
    display: flex;
  }

  #shopify-section-{{ section.id }} .dcway-blog__card {
    background: #ffffff;
    min-height: 550px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .dcway-blog__media {
    display: block;
    width: 100%;
    height: 270px;
    overflow: hidden;
    background: #f2f2f2;
  }
  #shopify-section-{{ section.id }} .dcway-blog__media img,
  #shopify-section-{{ section.id }} .dcway-blog__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }
  #shopify-section-{{ section.id }} .dcway-blog__body-text {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1 1 auto;
  }
  #shopify-section-{{ section.id }} .dcway-blog__title {
    margin: 10px 0 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 36px;
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--dcway-orange, #ff7200);
  }
  #shopify-section-{{ section.id }} .dcway-blog__title a {
    color: inherit;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .dcway-blog__title a:hover { text-decoration: underline; }
  #shopify-section-{{ section.id }} .dcway-blog__excerpt {
    margin: 0;
    color: #2c2c2c;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.5em;
    font-weight: 400;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
  }
  #shopify-section-{{ section.id }} .dcway-blog__cta-wrap {
    margin-top: auto;
    padding-top: 8px;
  }
  #shopify-section-{{ section.id }} .dcway-blog__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1;
    color: var(--dcway-orange, #ff7200);
    background: #ffffff;
    border: 2px solid var(--dcway-orange, #ff7200);
    padding: 12px 40px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-blog__cta:hover,
  #shopify-section-{{ section.id }} .dcway-blog__cta:focus-visible {
    background: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .dcway-blog__empty {
    text-align: center;
    color: #888;
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-blog__body {
      grid-template-columns: 4fr 8fr;
      gap: 30px;
    }
    #shopify-section-{{ section.id }} .dcway-blog__mascot {
      max-width: 100%;
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .dcway-blog__slide {
      flex-basis: calc((100% - 20px) / 2);
    }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-blog__heading { font-size: 36px; }
    #shopify-section-{{ section.id }} .dcway-blog__title { font-size: 30px; }
    #shopify-section-{{ section.id }} .dcway-blog__cta { font-size: 16px; padding: 10px 32px; }
    #shopify-section-{{ section.id }} .dcway-blog__media { height: 220px; }
    #shopify-section-{{ section.id }} .dcway-blog__card { min-height: auto; }
    #shopify-section-{{ section.id }} .dcway-blog__arrows {
      position: static;
      margin-top: 16px;
      justify-content: flex-end;
    }
  }
{%- endstyle -%}

<script>
  if (!window.customElements.get('dcway-blog')) {
    class DcwayBlog extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('.dcway-blog__track');
        this.arrows = this.querySelectorAll('.dcway-blog__arrow');
        if (!this.track) return;
        this.arrows.forEach((b) => {
          b.addEventListener('click', () => {
            const dir = parseInt(b.dataset.dir, 10);
            const slide = this.track.querySelector('.dcway-blog__slide');
            const step = slide ? (slide.getBoundingClientRect().width + 20) : 320;
            this.track.scrollBy({ left: dir * step, behavior: 'smooth' });
          });
        });
        this.track.addEventListener('scroll', () => this._updateArrows(), { passive: true });
        this._updateArrows();
      }
      _updateArrows() {
        if (!this.arrows.length) return;
        const max = this.track.scrollWidth - this.track.clientWidth;
        this.arrows[0].disabled = this.track.scrollLeft <= 4;
        this.arrows[1].disabled = this.track.scrollLeft >= max - 4;
      }
    }
    window.customElements.define('dcway-blog', DcwayBlog);
  }
</script>

{% schema %}
{
  "name": "Blog (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading_lead",
      "label": "Heading — lead word(s)",
      "default": "DC WAY"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — orange-accent word(s)",
      "default": "BLOG"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "Welcome to our blog, where we share updates, insights, and stories from the DC Way community! Whether you're a player, parent, coach, or fan, our blog is here to keep you informed, inspired, and connected with our vibrant community. Join us as we share insights, celebrate our players, and explore the exciting world of soccer!"
    },
    {
      "type": "image_picker",
      "id": "mascot_image",
      "label": "Decorative mascot image",
      "info": "Defaults to WP-style panda mascot."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Posts to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card CTA label",
      "default": "LEARN MORE"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Blog posts coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Blog (DC Way)"
    }
  ]
}
{% endschema %}
