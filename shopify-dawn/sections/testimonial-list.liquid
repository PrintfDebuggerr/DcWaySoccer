{%- liquid
  assign entries = shop.metaobjects['testimonial'].values | sort: 'position'
  assign cols = section.settings.columns_desktop | default: 2
-%}

<div class="dcway-testimonial-list color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="dcway-testimonial-list__heading dcway-uppercase">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if entries.size > 0 -%}
      <ul class="dcway-testimonial-list__grid" role="list" data-cols="{{ cols }}">
        {%- for entry in entries -%}
          <li class="dcway-testimonial-list__item">
            {%- render 'card-testimonial', testimonial: entry, show_rating: section.settings.show_rating -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="dcway-testimonial-list__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-testimonial-list {
    padding-block: 48px;
  }
  #shopify-section-{{ section.id }} .dcway-testimonial-list__heading {
    margin: 0 0 32px;
    font-size: 2rem;
    line-height: 1.1;
    font-weight: 700;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-testimonial-list__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr;
  }
  #shopify-section-{{ section.id }} .dcway-testimonial-list__item {
    display: flex;
  }
  #shopify-section-{{ section.id }} .dcway-testimonial-list__empty {
    text-align: center;
    color: var(--dcway-muted);
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-testimonial-list__grid[data-cols='2'] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-testimonial-list__grid[data-cols='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Testimonial list (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Parents Say"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show ratings",
      "default": true
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "No testimonials yet."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Testimonial list (DC Way)"
    }
  ]
}
{% endschema %}
