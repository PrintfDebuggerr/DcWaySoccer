{%- liquid
  assign features = section.blocks | where: 'type', 'feature'
-%}

<div class="dcway-why color-{{ section.settings.color_scheme }}">
  <div class="dcway-why__inner">
    {%- if section.settings.heading != blank -%}
      <div class="dcway-why__sidelabel" aria-hidden="true">
        <span>{{ section.settings.heading }}</span>
      </div>
      <h2 class="dcway-why__title-mobile">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="dcway-why__grid">
      {%- for block in features -%}
        <div class="dcway-why__cell dcway-why__cell--text" {{ block.shopify_attributes }}>
          <div class="dcway-why__cell-inner">
            {%- if block.settings.title != blank -%}
              <h3 class="dcway-why__cell-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="dcway-why__cell-body">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>
        </div>
        <div class="dcway-why__cell dcway-why__cell--image">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '300, 500, 700, 900, 1200',
                sizes: '(max-width: 749px) 100vw, 33vw',
                class: 'dcway-why__cell-img',
                alt: block.settings.image.alt | default: block.settings.title
            }}
          {%- else -%}
            <div class="dcway-why__cell-placeholder">
              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .dcway-why {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .dcway-why__inner {
    max-width: var(--dcway-container, 1170px);
    margin-inline: auto;
    padding-inline: 16px;
    position: relative;
  }
  #shopify-section-{{ section.id }} .dcway-why__sidelabel {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translate(-100%, -50%) rotate(-90deg);
    transform-origin: right center;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1;
    white-space: nowrap;
    color: var(--dcway-text, #333);
    pointer-events: none;
    padding-right: 24px;
  }
  #shopify-section-{{ section.id }} .dcway-why__title-mobile {
    display: none;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 32px;
    line-height: 1;
    margin: 0 0 24px;
    text-align: left;
  }
  #shopify-section-{{ section.id }} .dcway-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    position: relative;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell--text {
    background: var(--dcway-orange, #FF7200);
    color: #fff;
    display: flex;
    align-items: flex-start;
    padding: clamp(20px, 2.6vw, 36px);
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-title {
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(24px, 2.4vw, 36px);
    line-height: 1.05;
    margin: 0;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-body {
    font-size: clamp(14px, 1vw, 16px);
    line-height: 1.5;
    color: #fff;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-body p {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-img,
  #shopify-section-{{ section.id }} .dcway-why__cell-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .dcway-why__cell-placeholder {
    width: 100%;
    height: 100%;
    background: var(--dcway-muted-bg, #f2f2f2);
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .dcway-why__sidelabel { display: none; }
    #shopify-section-{{ section.id }} .dcway-why__title-mobile { display: block; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-why__grid {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .dcway-why__cell {
      aspect-ratio: 16 / 10;
    }
    #shopify-section-{{ section.id }} .dcway-why__cell--text {
      aspect-ratio: auto;
      min-height: 200px;
    }
  }
</style>

{% schema %}
{
  "name": "Why Soccer (About)",
  "tag": "section",
  "class": "section dcway-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Side label",
      "default": "WHY SOCCER?"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Text + image pair",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "NEW SKILLS"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>By choosing soccer, your child sets foot on a path that cultivates self-confidence, nurtures lifelong friendships, and instills invaluable life and physical skills.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (paired with this text)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Soccer (About)",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "NEW SKILLS",
            "body": "<p>By choosing soccer, your child sets foot on a path that cultivates self-confidence, nurtures lifelong friendships, and instills invaluable life and physical skills.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "AFFORDABILITY",
            "body": "<p>Soccer is a sport that's both exciting and accessible. With just a ball and minimal gear, it's easy for families to join in without a big expense.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "CULTURE",
            "body": "<p>Soccer is a sport with universal appeal — a game that connects communities, builds friendships, and teaches valuable life skills.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
