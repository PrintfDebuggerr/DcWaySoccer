{%- comment -%}
  WP-faithful port of DC Way's "FOLLOW US ON INSTAGRAM" home section.

  Layout:
    - Centered heading "FOLLOW US ON INSTAGRAM" (INSTAGRAM accent in orange).
    - Below: small Instagram glyph + @handle pill, centered, linking to the
      profile URL.
    - 4-column grid (2-up tablet / 2-up mobile) of square Instagram thumbnails.
      Each thumbnail is an <a> opening the live Instagram post in a new tab,
      with a play-icon overlay for video posts.
    - Hover: subtle dim + scale on the image.

  Posts are managed as section blocks; each block has a thumbnail image URL
  (CDN), post URL, alt text, and video flag. The default index.json seed
  contains 12 WP-faithful posts uploaded to Shopify Files via the bootstrap
  script.

  Reference: 03-saved-html-pages/01-home-main/DC Way Soccer.html lines 4866-5050.
{%- endcomment -%}

{%- liquid
  assign handle = section.settings.handle_text | default: '@DCWAYSOCCER'
  assign handle_url = section.settings.handle_url | default: 'https://www.instagram.com/dcwaysoccer/'
-%}

<div class="dcway-instagram color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <header class="dcway-instagram__head">
      <h2 class="dcway-instagram__heading dcway-uppercase">
        {%- if section.settings.heading_lead != blank -%}{{ section.settings.heading_lead }} {% endif -%}
        {%- if section.settings.heading_accent != blank -%}<span class="dcway-accent">{{ section.settings.heading_accent }}</span>{%- endif -%}
      </h2>
      {%- if handle != blank -%}
        <a class="dcway-instagram__handle" href="{{ handle_url }}" target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M7.74863 1.79883C6.17046 1.79883 4.65689 2.4256 3.54074 3.54132C2.42459 4.65704 1.79724 6.17037 1.79663 7.74854V23.6205C1.79663 25.1991 2.42371 26.713 3.53993 27.8292C4.65615 28.9455 6.17006 29.5725 7.74863 29.5725H23.6206C25.1988 29.5719 26.7121 28.9446 27.8279 27.8284C28.9436 26.7123 29.5703 25.1987 29.5703 23.6205V7.74854C29.5697 6.17077 28.9427 4.65778 27.827 3.54213C26.7114 2.42647 25.1984 1.79943 23.6206 1.79883H7.74863ZM25.3326 7.75769C25.3326 8.21234 25.152 8.64838 24.8305 8.96987C24.509 9.29136 24.073 9.47197 23.6183 9.47197C23.1637 9.47197 22.7276 9.29136 22.4062 8.96987C22.0847 8.64838 21.9041 8.21234 21.9041 7.75769C21.9041 7.30303 22.0847 6.86699 22.4062 6.5455C22.7276 6.22401 23.1637 6.0434 23.6183 6.0434C24.073 6.0434 24.509 6.22401 24.8305 6.5455C25.152 6.86699 25.3326 7.30303 25.3326 7.75769ZM15.6869 10.9303C14.426 10.9303 13.2167 11.4312 12.3251 12.3228C11.4335 13.2144 10.9326 14.4236 10.9326 15.6845C10.9326 16.9455 11.4335 18.1547 12.3251 19.0463C13.2167 19.9379 14.426 20.4388 15.6869 20.4388C16.9478 20.4388 18.1571 19.9379 19.0487 19.0463C19.9403 18.1547 20.4412 16.9455 20.4412 15.6845C20.4412 14.4236 19.9403 13.2144 19.0487 12.3228C18.1571 11.4312 16.9478 10.9303 15.6869 10.9303ZM8.64463 15.6845C8.64463 13.8174 9.38634 12.0268 10.7066 10.7065C12.0269 9.38625 13.8175 8.64454 15.6846 8.64454C17.5518 8.64454 19.3424 9.38625 20.6627 10.7065C21.9829 12.0268 22.7246 13.8174 22.7246 15.6845C22.7246 17.5517 21.9829 19.3423 20.6627 20.6626C19.3424 21.9828 17.5518 22.7245 15.6846 22.7245C13.8175 22.7245 12.0269 21.9828 10.7066 20.6626C9.38634 19.3423 8.64463 17.5517 8.64463 15.6845Z" fill="currentColor"/>
          </svg>
          <span>{{ handle }}</span>
        </a>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <ul class="dcway-instagram__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign img_url = blank
            if block.settings.image_url != blank
              assign img_url = block.settings.image_url
            elsif block.settings.image != blank
              assign img_url = block.settings.image | image_url: width: 600
            endif
            assign post_url = block.settings.post_url
            assign is_video = block.settings.is_video
            assign alt_text = block.settings.alt | default: section.settings.default_alt | default: 'DC Way Soccer on Instagram'
          -%}
          {%- if img_url != blank -%}
            <li class="dcway-instagram__cell" {{ block.shopify_attributes }}>
              <a class="dcway-instagram__link" href="{{ post_url | default: handle_url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ alt_text | escape }}">
                <img class="dcway-instagram__img" src="{{ img_url }}" alt="{{ alt_text | escape }}" loading="lazy">
                {%- if is_video -%}
                  <span class="dcway-instagram__play" aria-hidden="true">
                    <svg width="48" height="48" viewBox="0 0 448 512" fill="none">
                      <path fill="#ffffff" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
                    </svg>
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="dcway-instagram__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-instagram {
    padding-block: 64px;
  }
  #shopify-section-{{ section.id }} .dcway-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .dcway-instagram__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__heading {
    margin: 0;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 48px;
    line-height: 1;
    font-weight: 700;
    color: #2c2c2c;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__heading .dcway-accent {
    color: var(--dcway-orange, #ff7200);
  }
  #shopify-section-{{ section.id }} .dcway-instagram__handle {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #2c2c2c;
    text-decoration: none;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__handle svg {
    color: var(--dcway-orange, #ff7200);
    flex: 0 0 auto;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__handle:hover {
    color: var(--dcway-orange, #ff7200);
  }

  #shopify-section-{{ section.id }} .dcway-instagram__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__cell {
    position: relative;
    overflow: hidden;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__link {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 0.35s ease, opacity 0.25s ease;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__link:hover .dcway-instagram__img {
    transform: scale(1.05);
    opacity: 0.92;
  }
  #shopify-section-{{ section.id }} .dcway-instagram__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
  }
  #shopify-section-{{ section.id }} .dcway-instagram__play svg {
    width: 36px;
    height: 36px;
  }

  #shopify-section-{{ section.id }} .dcway-instagram__empty {
    text-align: center;
    color: #888;
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-instagram__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-instagram__heading { font-size: 32px; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Instagram (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "max_blocks": 24,
  "settings": [
    {
      "type": "text",
      "id": "heading_lead",
      "label": "Heading — lead word(s)",
      "default": "FOLLOW US ON"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — orange-accent word(s)",
      "default": "INSTAGRAM"
    },
    {
      "type": "text",
      "id": "handle_text",
      "label": "Instagram handle",
      "default": "@DCWAYSOCCER"
    },
    {
      "type": "text",
      "id": "handle_url",
      "label": "Instagram profile URL",
      "default": "https://www.instagram.com/dcwaysoccer/"
    },
    {
      "type": "text",
      "id": "default_alt",
      "label": "Default thumbnail alt",
      "default": "DC Way Soccer on Instagram"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Add Instagram posts in the theme editor."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Thumbnail URL (overrides picker)",
          "info": "Paste a Shopify Files CDN URL to use without an image_picker reference."
        },
        {
          "type": "url",
          "id": "post_url",
          "label": "Instagram post URL"
        },
        {
          "type": "checkbox",
          "id": "is_video",
          "label": "Video post",
          "default": false
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram (DC Way)",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
