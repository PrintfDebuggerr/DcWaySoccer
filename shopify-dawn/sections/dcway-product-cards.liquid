{%- comment -%}
  WP-faithful port of DC Way's "OUR PROGRAMS" + "OUR CAMPS" sections.
  Markup mirrors the original .program-link / .program-inner structure (image on
  top, orange uppercase title, 4-line clamped description, outline SIGN UP
  button). Header has orange-accent heading + right-aligned "View all" + prev/
  next arrows. Card carousel — 3 visible desktop / 2 tablet / 1 mobile.

  Reusable: drop two instances on a page, one bound to `programs` and one to a
  camps collection. Single section file handles both WP sections.
{%- endcomment -%}

{%- liquid
  assign source = section.settings.collection
  assign limit = section.settings.product_limit | default: 9
  assign cols = section.settings.columns_desktop | default: 3
  assign view_all_text = section.settings.view_all_label | default: 'View all'
  assign cta_text = section.settings.cta_label | default: 'SIGN UP'
-%}

<div class="dcway-product-cards color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <div class="dcway-product-cards__head">
      <h2 class="dcway-product-cards__heading dcway-uppercase">
        {%- if section.settings.heading_lead != blank -%}{{ section.settings.heading_lead }} {% endif -%}
        {%- if section.settings.heading_accent != blank -%}<span class="dcway-accent">{{ section.settings.heading_accent }}</span>{%- endif -%}
      </h2>
      <div class="dcway-product-cards__head-right">
        {%- if section.settings.show_view_all and source.url != blank -%}
          <a class="dcway-product-cards__viewall" href="{{ source.url }}">
            {{ view_all_text }}
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M10.9392 9.00387L5.68923 14.2517L6.74989 15.3119L13.0605 9.00387L6.74989 2.69585L5.68923 3.75607L10.9392 9.00387Z" fill="currentColor" stroke="currentColor" stroke-linecap="square"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if source != blank and source.products_count > 0 -%}
      <dcway-product-cards class="dcway-product-cards__shell" data-cols="{{ cols }}" data-count="{{ source.products_count | at_most: limit }}">
        <ul class="dcway-product-cards__track" role="list">
          {%- for product in source.products limit: limit -%}
            {%- liquid
              assign desc = product.metafields.dcway.card_description.value | default: product.description | strip_html
              assign desc = desc | strip_newlines | truncatewords: 40
            -%}
            <li class="dcway-product-cards__slide">
              <a class="dcway-product-cards__card" href="{{ product.url }}">
                <div class="dcway-product-cards__card-inner">
                  <div class="dcway-product-cards__media">
                    {%- if product.featured_media -%}
                      {{ product.featured_media | image_url: width: 900 | image_tag:
                        loading: 'lazy',
                        widths: '300,500,700,900',
                        sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                        alt: product.featured_media.alt | default: product.title
                      }}
                    {%- else -%}
                      <div class="dcway-product-cards__placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </div>
                  <h3 class="dcway-product-cards__title dcway-uppercase">{{ product.title }}</h3>
                  {%- if desc != blank -%}
                    <p class="dcway-product-cards__desc">{{ desc }}</p>
                  {%- endif -%}
                  <div class="dcway-product-cards__cta-wrap">
                    <span class="dcway-product-cards__cta dcway-uppercase">{{ cta_text }}</span>
                  </div>
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if source.products_count > cols -%}
          <div class="dcway-product-cards__arrows" role="group" aria-label="Carousel controls">
            <button type="button" class="dcway-product-cards__arrow" data-dir="-1" aria-label="Previous">
              <svg width="14" height="14" viewBox="0 0 320 512" aria-hidden="true">
                <path fill="currentColor" d="M34.52 239.03L228.87 44.69c9.37-9.37 24.57-9.37 33.94 0l22.67 22.67c9.36 9.36 9.37 24.52.04 33.9L131.49 256l154.02 154.75c9.34 9.38 9.32 24.54-.04 33.9l-22.67 22.67c-9.37 9.37-24.57 9.37-33.94 0L34.52 272.97c-9.37-9.37-9.37-24.57 0-33.94z"/>
              </svg>
            </button>
            <button type="button" class="dcway-product-cards__arrow" data-dir="1" aria-label="Next">
              <svg width="14" height="14" viewBox="0 0 1000 1000" aria-hidden="true">
                <path fill="currentColor" d="M696 533C708 521 713 504 713 487 713 471 708 454 696 446L400 146C388 133 375 125 354 125 338 125 325 129 313 142 300 154 292 171 292 187 292 204 296 221 308 233L563 492 304 771C292 783 288 800 288 817 288 833 296 850 308 863 321 871 338 875 354 875 371 875 388 867 400 854L696 533Z"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </dcway-product-cards>
    {%- else -%}
      <p class="dcway-product-cards__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-product-cards {
    padding-block: 64px;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 32px;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__heading {
    margin: 0;
    font-size: 2.6rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__heading .dcway-accent { color: var(--dcway-orange); }
  #shopify-section-{{ section.id }} .dcway-product-cards__head-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__viewall {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--dcway-dark);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__viewall:hover { color: var(--dcway-orange); }

  #shopify-section-{{ section.id }} .dcway-product-cards__shell {
    display: block;
    position: relative;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__track::-webkit-scrollbar { display: none; }

  /* Slide width: 1-up mobile, 2-up tablet, configurable on desktop. */
  #shopify-section-{{ section.id }} .dcway-product-cards__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }
  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-product-cards__slide {
      flex-basis: calc((100% - 24px) / 2);
    }
  }
  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .dcway-product-cards__shell[data-cols='3'] .dcway-product-cards__slide {
      flex-basis: calc((100% - 48px) / 3);
    }
    #shopify-section-{{ section.id }} .dcway-product-cards__shell[data-cols='4'] .dcway-product-cards__slide {
      flex-basis: calc((100% - 72px) / 4);
    }
  }

  #shopify-section-{{ section.id }} .dcway-product-cards__card {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__card-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #ffffff;
    height: 100%;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__media {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--dcway-muted-bg);
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__media img,
  #shopify-section-{{ section.id }} .dcway-product-cards__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__title {
    margin: 0;
    padding: 0 20px;
    font-family: var(--font-heading-family, inherit);
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--dcway-orange);
    letter-spacing: -0.005em;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__desc {
    margin: 0;
    padding: 0 20px;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--dcway-text);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__cta-wrap {
    padding: 12px 20px 20px;
    margin-top: auto;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family, inherit);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--dcway-orange);
    background: #ffffff;
    border: 2px solid var(--dcway-orange);
    padding: 11px 36px;
    letter-spacing: 0.04em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__card:hover .dcway-product-cards__cta {
    background: var(--dcway-orange);
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .dcway-product-cards__arrows {
    display: flex;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__arrow {
    width: 44px;
    height: 44px;
    padding: 0;
    background: #ffffff;
    border: 2px solid var(--dcway-orange);
    color: var(--dcway-orange);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__arrow:hover {
    background: var(--dcway-orange);
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__arrow:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: #ffffff;
    color: var(--dcway-orange);
  }
  #shopify-section-{{ section.id }} .dcway-product-cards__empty {
    text-align: center;
    color: var(--dcway-muted);
    font-style: italic;
    margin: 0;
  }
{%- endstyle -%}

<script>
  if (!window.customElements.get('dcway-product-cards')) {
    class DcwayProductCards extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('.dcway-product-cards__track');
        this.arrows = this.querySelectorAll('.dcway-product-cards__arrow');
        if (!this.track) return;
        this.arrows.forEach((b) => {
          b.addEventListener('click', () => {
            const dir = parseInt(b.dataset.dir, 10);
            const slide = this.track.querySelector('.dcway-product-cards__slide');
            const step = slide ? (slide.getBoundingClientRect().width + 24) : 300;
            this.track.scrollBy({ left: dir * step, behavior: 'smooth' });
          });
        });
        this.track.addEventListener('scroll', () => this._updateArrows(), { passive: true });
        this._updateArrows();
      }
      _updateArrows() {
        if (!this.arrows.length) return;
        const max = this.track.scrollWidth - this.track.clientWidth;
        this.arrows[0].disabled = this.track.scrollLeft <= 4;
        this.arrows[1].disabled = this.track.scrollLeft >= max - 4;
      }
    }
    window.customElements.define('dcway-product-cards', DcwayProductCards);
  }
</script>

{% schema %}
{
  "name": "Product cards (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading_lead",
      "label": "Heading — lead word(s)",
      "default": "OUR"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading — orange-accent word(s)",
      "default": "PROGRAMS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Maximum cards",
      "min": 3,
      "max": 18,
      "step": 1,
      "default": 9
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card CTA label",
      "default": "SIGN UP"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' label",
      "default": "View all"
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "Coming soon."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Product cards (DC Way)"
    }
  ]
}
{% endschema %}
