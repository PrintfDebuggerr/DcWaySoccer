{%- liquid
  assign cols = section.settings.columns_desktop | default: 4
  assign blocks = section.blocks
-%}

<div class="dcway-instagram-feed color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container">
    <div class="dcway-instagram-feed__head">
      {%- if section.settings.heading != blank -%}
        <h2 class="dcway-instagram-feed__heading dcway-uppercase">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.handle_text != blank -%}
        <a class="dcway-instagram-feed__handle" href="{{ section.settings.handle_url | default: '#' }}" target="_blank" rel="noopener">
          {{ section.settings.handle_text }}
        </a>
      {%- endif -%}
    </div>

    {%- if blocks.size > 0 -%}
      <ul class="dcway-instagram-feed__grid" role="list" data-cols="{{ cols }}">
        {%- for block in blocks -%}
          <li class="dcway-instagram-feed__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a class="dcway-instagram-feed__link" href="{{ block.settings.link }}" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'View on Instagram' | escape }}">
            {%- endif -%}
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  widths: '200,400,600,800',
                  sizes: '(min-width: 750px) 25vw, 50vw',
                  alt: block.settings.alt
                }}
              {%- else -%}
                <div class="dcway-instagram-feed__placeholder" aria-hidden="true">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="dcway-instagram-feed__empty">{{ section.settings.empty_state_text }}</p>
    {%- endif -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-instagram-feed {
    padding-block: 48px;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-bottom: 24px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__heading {
    margin: 0;
    font-size: 2rem;
    line-height: 1.1;
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__handle {
    color: var(--dcway-orange);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__handle:hover {
    text-decoration: underline;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--dcway-muted-bg);
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__item img,
  #shopify-section-{{ section.id }} .dcway-instagram-feed__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__link {
    display: block;
    width: 100%;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__link img {
    transition: transform 0.4s ease;
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__link:hover img {
    transform: scale(1.05);
  }
  #shopify-section-{{ section.id }} .dcway-instagram-feed__empty {
    text-align: center;
    color: var(--dcway-muted);
    font-style: italic;
    margin: 0;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .dcway-instagram-feed__grid[data-cols='3'] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-instagram-feed__grid[data-cols='4'] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-instagram-feed__grid[data-cols='5'] {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
    #shopify-section-{{ section.id }} .dcway-instagram-feed__grid[data-cols='6'] {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Instagram feed (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "handle_text",
      "label": "Handle text",
      "default": "@dcwaysoccer"
    },
    {
      "type": "url",
      "id": "handle_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "empty_state_text",
      "label": "Empty-state text",
      "default": "No Instagram posts yet."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram post URL"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "default": "DC Way Soccer on Instagram"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram feed (DC Way)",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
