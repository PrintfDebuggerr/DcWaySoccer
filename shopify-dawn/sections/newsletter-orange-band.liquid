{%- liquid
  assign band_id = 'NewsletterBand-' | append: section.id
  assign input_id = band_id | append: '-Email'
  assign error_id = band_id | append: '-Error'
  assign success_id = band_id | append: '-Success'
-%}

<div class="dcway-newsletter-band">
  <div class="dcway-container dcway-newsletter-band__inner">
    <div class="dcway-newsletter-band__copy">
      <div class="dcway-newsletter-band__heading-row">
        <span class="dcway-newsletter-band__icon" aria-hidden="true">
          <svg width="44" height="34" viewBox="0 0 44 34" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 4h36c1.1 0 2 .9 2 2v22c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 19L4 7v2l18 12L40 9V7L22 19z" fill="currentColor"/>
          </svg>
        </span>
        {%- if section.settings.heading != blank -%}
          <h2 class="dcway-newsletter-band__heading dcway-uppercase">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.body_text != blank -%}
        <p class="dcway-newsletter-band__body">{{ section.settings.body_text }}</p>
      {%- endif -%}
    </div>

    <div class="dcway-newsletter-band__form-wrap">
      {%- form 'customer', id: band_id, class: 'dcway-newsletter-band__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="dcway-visually-hidden" for="{{ input_id }}">{{ section.settings.email_placeholder }}</label>
        <div class="dcway-newsletter-band__field">
          <input
            type="email"
            id="{{ input_id }}"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ section.settings.email_placeholder }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            aria-required="true"
            {%- if form.errors %} aria-invalid="true" aria-describedby="{{ error_id }}"{% endif -%}
            {%- if form.posted_successfully? %} aria-describedby="{{ success_id }}"{% endif -%}
            required
          >
          <button type="submit" name="commit" class="dcway-newsletter-band__submit dcway-uppercase">
            {{ section.settings.submit_label }}
          </button>
        </div>

        {%- if form.errors -%}
          <p id="{{ error_id }}" class="dcway-newsletter-band__message dcway-newsletter-band__message--error" role="alert">
            {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
          </p>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <p id="{{ success_id }}" class="dcway-newsletter-band__message dcway-newsletter-band__message--success" role="status">
            {{- 'newsletter.success' | t -}}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-newsletter-band {
    background: #ece6dd;
    color: var(--dcway-dark);
    padding-block: 48px;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 40px;
    justify-content: space-between;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__copy {
    flex: 1 1 460px;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__heading-row {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 10px;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__icon {
    display: inline-flex;
    color: var(--dcway-orange);
    flex: 0 0 auto;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__icon svg {
    display: block;
    width: 56px;
    height: auto;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__heading {
    margin: 0;
    font-size: 2.125rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: 0.01em;
    color: var(--dcway-dark);
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__body {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--dcway-text);
    max-width: 64ch;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__form-wrap {
    flex: 1 1 420px;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__form {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field {
    display: flex;
    background: transparent;
    border: 0;
    gap: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field input[type='email'] {
    flex: 1 1 auto;
    min-width: 0;
    border: 1px solid #cdc7bd;
    background: #fff;
    padding: 18px 20px;
    font-family: inherit;
    font-size: 1rem;
    color: var(--dcway-text);
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field input[type='email']:focus {
    outline: 2px solid var(--dcway-orange);
    outline-offset: -2px;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__submit {
    flex: 0 0 auto;
    border: 0;
    padding: 18px 44px;
    font-family: inherit;
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: var(--dcway-tracking-button);
    background: var(--dcway-orange);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__submit:hover {
    background: var(--dcway-orange-hover);
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__message {
    margin: 8px 0 0;
    font-size: 0.875rem;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__message--error {
    color: #b00020;
    font-weight: 600;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__message--success {
    color: #1f7a3a;
    font-weight: 600;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-newsletter-band {
      padding-block: 24px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__inner {
      flex-direction: column;
      align-items: stretch;
      text-align: left;
      gap: 16px;
      padding-inline: 20px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__copy,
    #shopify-section-{{ section.id }} .dcway-newsletter-band__form-wrap {
      flex: 0 0 auto;
      width: 100%;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__heading {
      font-size: 1.5rem;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__body {
      font-size: 0.9375rem;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__icon svg {
      width: 40px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__field {
      flex-direction: column;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__submit {
      padding: 14px 24px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Newsletter band (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR NEWSLETTER!"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Body text",
      "default": "Our programs fill up fast! If you don't want to miss out on the best soccer programs around, then join our EMAIL LIST for news and information the moment it is released!"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "E-mail address"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Sign up"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme (legacy, ignored — section uses fixed cream/orange)",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Newsletter band (DC Way)"
    }
  ],
  "enabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
