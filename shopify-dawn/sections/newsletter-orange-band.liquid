{%- liquid
  assign band_id = 'NewsletterBand-' | append: section.id
  assign input_id = band_id | append: '-Email'
  assign error_id = band_id | append: '-Error'
  assign success_id = band_id | append: '-Success'
-%}

<div class="dcway-newsletter-band color-{{ section.settings.color_scheme }} gradient">
  <div class="dcway-container dcway-newsletter-band__inner">
    <div class="dcway-newsletter-band__copy">
      {%- if section.settings.heading != blank -%}
        <h2 class="dcway-newsletter-band__heading dcway-uppercase">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body_text != blank -%}
        <p class="dcway-newsletter-band__body">{{ section.settings.body_text }}</p>
      {%- endif -%}
    </div>

    <div class="dcway-newsletter-band__form-wrap">
      {%- form 'customer', id: band_id, class: 'dcway-newsletter-band__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="dcway-visually-hidden" for="{{ input_id }}">{{ section.settings.email_placeholder }}</label>
        <div class="dcway-newsletter-band__field">
          <input
            type="email"
            id="{{ input_id }}"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ section.settings.email_placeholder }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            aria-required="true"
            {%- if form.errors %} aria-invalid="true" aria-describedby="{{ error_id }}"{% endif -%}
            {%- if form.posted_successfully? %} aria-describedby="{{ success_id }}"{% endif -%}
            required
          >
          <button type="submit" name="commit" class="dcway-newsletter-band__submit dcway-uppercase">
            {{ section.settings.submit_label }}
          </button>
        </div>

        {%- if form.errors -%}
          <p id="{{ error_id }}" class="dcway-newsletter-band__message dcway-newsletter-band__message--error" role="alert">
            {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
          </p>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <p id="{{ success_id }}" class="dcway-newsletter-band__message dcway-newsletter-band__message--success" role="status">
            {{- 'newsletter.success' | t -}}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .dcway-newsletter-band {
    padding-block: 28px;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    justify-content: space-between;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__copy {
    flex: 1 1 320px;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__heading {
    margin: 0 0 4px;
    font-size: 1.6rem;
    line-height: 1.2;
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__body {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.4;
    opacity: 0.95;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__form-wrap {
    flex: 1 1 360px;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__form {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field {
    display: flex;
    background: #fff;
    border: 0;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field input[type='email'] {
    flex: 1 1 auto;
    min-width: 0;
    border: 0;
    background: transparent;
    padding: 12px 14px;
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--dcway-text);
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__field input[type='email']:focus {
    outline: 2px solid var(--dcway-dark);
    outline-offset: -2px;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__submit {
    flex: 0 0 auto;
    border: 0;
    padding: 12px 24px;
    font-family: inherit;
    font-weight: 700;
    font-size: 0.9375rem;
    background: var(--dcway-dark);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__submit:hover {
    background: #000;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__message {
    margin: 8px 0 0;
    font-size: 0.875rem;
  }
  #shopify-section-{{ section.id }} .dcway-newsletter-band__message--error {
    color: #fff;
    font-weight: 600;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .dcway-newsletter-band {
      padding-block: 20px;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__inner {
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      text-align: center;
      gap: 14px;
      padding-inline: 20px;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__copy {
      flex: 0 0 auto;
      width: 100%;
      max-width: 360px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__heading {
      font-size: 1.25rem;
      margin-bottom: 4px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__body {
      font-size: 0.875rem;
      line-height: 1.35;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__form-wrap {
      flex: 0 0 auto;
      width: 100%;
      max-width: 360px;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__field {
      flex-direction: column;
      gap: 0;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__field input[type='email'] {
      padding: 12px 14px;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .dcway-newsletter-band__submit {
      padding: 12px 24px;
      font-size: 0.875rem;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Newsletter band (DC Way)",
  "tag": "section",
  "class": "section dcway-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN OUR NEWSLETTER!"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Body text",
      "default": "Don't miss out on a single update. Sign up below."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Sign up"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "presets": [
    {
      "name": "Newsletter band (DC Way)"
    }
  ],
  "enabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
