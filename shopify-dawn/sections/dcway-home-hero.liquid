{%- liquid
  assign overlay = section.settings.overlay_opacity | default: 44
  assign height_d = section.settings.height_desktop | default: 560
  assign height_m = section.settings.height_mobile | default: 420
-%}

<section class="dcway-home-hero color-{{ section.settings.color_scheme }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="dcway-home-hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '600, 900, 1200, 1600, 2000, 2600, 3000',
          sizes: '100vw',
          class: 'dcway-home-hero__img',
          alt: section.settings.image.alt | default: section.settings.heading
      }}
    {%- else -%}
      <div class="dcway-home-hero__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="dcway-home-hero__overlay" style="opacity: {{ overlay | times: 0.01 }};" aria-hidden="true"></div>
  </div>

  <div class="dcway-home-hero__inner">
    <div class="dcway-home-hero__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="dcway-home-hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="dcway-home-hero__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a class="dcway-home-hero__button" href="{{ section.settings.button_link }}">
          {{- section.settings.button_label -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .dcway-home-hero {
    position: relative;
    width: 100%;
    height: {{ height_d }}px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__media {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__img,
  #shopify-section-{{ section.id }} .dcway-home-hero__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.focal_point }};
    display: block;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__overlay {
    position: absolute;
    inset: 0;
    background-color: #020101;
    z-index: 1;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 20px;
    height: 100%;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__content {
    max-width: 800px;
    padding-top: 100px;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__title {
    color: #ffffff;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 72px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__subtitle {
    color: #ffffff;
    font-family: 'Nunito Sans', Tahoma, Arial, sans-serif;
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.02px;
    text-transform: uppercase;
    margin: 0 0 40px;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__button {
    display: inline-block;
    font-family: 'Barlow Condensed', 'Barlow', Tahoma, Arial, sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    background-color: transparent;
    border: 2px solid var(--dcway-orange, #ff7200);
    padding: 17px 55px;
    transition: background-color 0.25s ease, color 0.25s ease;
  }
  #shopify-section-{{ section.id }} .dcway-home-hero__button:hover,
  #shopify-section-{{ section.id }} .dcway-home-hero__button:focus-visible {
    background-color: var(--dcway-orange, #ff7200);
    color: #ffffff;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .dcway-home-hero {
      height: {{ height_m }}px;
    }
    #shopify-section-{{ section.id }} .dcway-home-hero__content {
      padding-top: 60px;
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .dcway-home-hero__title {
      font-size: 44px;
    }
    #shopify-section-{{ section.id }} .dcway-home-hero__subtitle {
      font-size: 18px;
      margin-bottom: 28px;
    }
    #shopify-section-{{ section.id }} .dcway-home-hero__button {
      font-size: 18px;
      padding: 14px 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Home hero",
  "tag": "section",
  "class": "section dcway-section dcway-section--flush",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "Focal point",
      "options": [
        { "value": "center top", "label": "Top" },
        { "value": "center center", "label": "Center" },
        { "value": "center bottom", "label": "Bottom" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 44
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height (px)",
      "min": 360,
      "max": 760,
      "step": 20,
      "default": 560
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height (px)",
      "min": 280,
      "max": 600,
      "step": 20,
      "default": 420
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DC Way Soccer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Score Fun, Kick Goals & Shine!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Home hero"
    }
  ]
}
{% endschema %}
