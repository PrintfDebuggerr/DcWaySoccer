{%- liquid
  assign menu = linklists[section.settings.menu]
  assign logo = section.settings.logo
  assign logo_url = section.settings.logo_url
  assign logo_width = section.settings.logo_width | default: 180
-%}

<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

<dcway-header class="dcway-header" data-sticky="{{ section.settings.sticky }}">
  <div class="dcway-header__inner">
    <!-- Mobile: hamburger -->
    <button
      type="button"
      class="dcway-header__hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      data-dcway-header-toggle
    >
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="dcway-header__logo" aria-label="{{ shop.name | escape }}">
      {%- if logo != blank -%}
        {{ logo
          | image_url: width: 600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '180, 360, 540, 720',
            sizes: '180px',
            class: 'dcway-header__logo-img',
            alt: shop.name,
            style: 'max-width:' | append: logo_width | append: 'px;'
        }}
      {%- elsif logo_url != blank -%}
        <img
          src="{{ logo_url }}"
          alt="{{ shop.name | escape }}"
          class="dcway-header__logo-img"
          loading="eager"
          fetchpriority="high"
          style="max-width:{{ logo_width }}px;"
        >
      {%- else -%}
        <span class="dcway-header__logo-text">DC WAY</span>
      {%- endif -%}
    </a>

    <!-- Desktop nav -->
    <nav class="dcway-header__nav" aria-label="Primary">
      <ul class="dcway-header__menu" role="list">
        {%- for link in menu.links -%}
          <li class="dcway-header__menu-item {% if link.links.size > 0 %}dcway-header__menu-item--has-children{% endif %} {% if link.active or link.child_active %}is-active{% endif %}">
            <a class="dcway-header__menu-link" href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title }}
              {%- if link.links.size > 0 -%}
                <svg class="dcway-header__caret" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                  <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="dcway-header__submenu" role="list">
                {%- for sub in link.links -%}
                  <li class="dcway-header__submenu-item">
                    <a class="dcway-header__submenu-link" href="{{ sub.url }}" {% if sub.active %}aria-current="page"{% endif %}>{{ sub.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <!-- Right cluster: search, cart, login -->
    <div class="dcway-header__actions">
      <button
        type="button"
        class="dcway-header__search-toggle"
        aria-label="Search"
        aria-expanded="false"
        data-dcway-search-toggle
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
          <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>

      <a href="{{ routes.cart_url }}" class="dcway-header__cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" fill="currentColor"/>
        </svg>
        <span class="dcway-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </a>

      {%- if section.settings.login_label != blank -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ section.settings.login_url | default: routes.account_login_url }}{% endif %}"
          class="dcway-header__login"
        >
          {%- if customer -%}{{ section.settings.account_label | default: 'My Account' }}{%- else -%}{{ section.settings.login_label }}{%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- Predictive search panel -->
  <div class="dcway-header__search" data-dcway-search-panel hidden>
    <div class="dcway-header__search-inner">
      <form action="{{ routes.search_url }}" method="get" role="search" class="dcway-header__search-form">
        <span class="dcway-header__search-field">
          <svg class="dcway-header__search-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            name="q"
            class="dcway-header__search-input"
            placeholder="{{ 'general.search.search' | t | default: 'Search camps, programs, pages…' }}"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Search"
            data-dcway-search-input
          >
          <button type="button" class="dcway-header__search-clear" aria-label="Clear search" data-dcway-search-clear hidden>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </span>
        <button type="button" class="dcway-header__search-close" aria-label="Close search" data-dcway-search-close>
          {{ 'accessibility.close' | t | default: 'Close' }}
        </button>
      </form>
      <div class="dcway-header__search-results" data-dcway-search-results aria-live="polite" role="listbox"></div>
    </div>
  </div>
  <div class="dcway-header__search-backdrop" data-dcway-search-backdrop hidden></div>

  <!-- Mobile drawer -->
  <div class="dcway-header__drawer" data-dcway-header-drawer aria-hidden="true">
    <div class="dcway-header__drawer-inner">
      <ul class="dcway-header__drawer-menu" role="list">
        {%- for link in menu.links -%}
          <li class="dcway-header__drawer-item {% if link.links.size > 0 %}dcway-header__drawer-item--group{% endif %}">
            {%- if link.links.size > 0 -%}
              <button type="button" class="dcway-header__drawer-toggle" aria-expanded="false" data-dcway-drawer-group>
                {{ link.title }}
                <svg viewBox="0 0 12 8" fill="none" aria-hidden="true">
                  <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <ul class="dcway-header__drawer-sub" role="list" hidden>
                <li><a class="dcway-header__drawer-sub-link" href="{{ link.url }}">{{ link.title }}</a></li>
                {%- for sub in link.links -%}
                  <li><a class="dcway-header__drawer-sub-link" href="{{ sub.url }}">{{ sub.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <a class="dcway-header__drawer-link" href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.login_label != blank -%}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ section.settings.login_url | default: routes.account_login_url }}{% endif %}"
          class="dcway-header__drawer-cta"
        >
          {%- if customer -%}{{ section.settings.account_label | default: 'My Account' }}{%- else -%}{{ section.settings.login_label }}{%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</dcway-header>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: section.settings.menu_type_desktop -%}
{%- endif -%}

<script>
  if (!customElements.get('dcway-header')) {
    customElements.define('dcway-header', class DcwayHeader extends HTMLElement {
      connectedCallback() {
        this.toggleBtn = this.querySelector('[data-dcway-header-toggle]');
        this.drawer = this.querySelector('[data-dcway-header-drawer]');
        if (this.toggleBtn && this.drawer) {
          this.toggleBtn.addEventListener('click', () => this.toggleDrawer());
        }
        this.querySelectorAll('[data-dcway-drawer-group]').forEach((btn) => {
          btn.addEventListener('click', () => {
            var expanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', String(!expanded));
            var sub = btn.nextElementSibling;
            if (sub) sub.hidden = expanded;
          });
        });

        // Predictive search
        this.searchToggle = this.querySelector('[data-dcway-search-toggle]');
        this.searchPanel = this.querySelector('[data-dcway-search-panel]');
        this.searchInput = this.querySelector('[data-dcway-search-input]');
        this.searchResults = this.querySelector('[data-dcway-search-results]');
        this.searchClose = this.querySelector('[data-dcway-search-close]');
        this.searchClear = this.querySelector('[data-dcway-search-clear]');
        this.searchBackdrop = this.querySelector('[data-dcway-search-backdrop]');
        this.searchActive = -1;
        if (this.searchToggle && this.searchPanel && this.searchInput) {
          this.searchToggle.addEventListener('click', () => this.toggleSearch());
          if (this.searchClose) this.searchClose.addEventListener('click', () => this.closeSearch());
          if (this.searchBackdrop) this.searchBackdrop.addEventListener('click', () => this.closeSearch());
          if (this.searchClear) this.searchClear.addEventListener('click', () => {
            this.searchInput.value = '';
            this.searchClear.setAttribute('hidden', '');
            this.renderInitial();
            this.searchInput.focus();
          });
          document.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.closeSearch(); });
          var debounce;
          this.searchInput.addEventListener('input', () => {
            clearTimeout(debounce);
            var q = this.searchInput.value.trim();
            if (this.searchClear) this.searchClear.toggleAttribute('hidden', q.length === 0);
            if (q.length < 2) { this.renderInitial(); return; }
            this.renderLoading();
            debounce = setTimeout(() => this.runSearch(q), 250);
          });
          this.searchInput.addEventListener('keydown', (e) => this.onSearchKey(e));
        }

        // Drop-shadow when scrolled past header (sticky pos handled by CSS).
        if (this.dataset.sticky !== 'false') {
          window.addEventListener('scroll', () => {
            if (window.scrollY > 60) this.classList.add('is-scrolled');
            else this.classList.remove('is-scrolled');
          }, { passive: true });
        }
      }
      toggleDrawer() {
        var open = this.drawer.getAttribute('aria-hidden') === 'false';
        this.drawer.setAttribute('aria-hidden', String(open));
        this.toggleBtn.setAttribute('aria-expanded', String(!open));
        document.body.style.overflow = open ? '' : 'hidden';
      }
      toggleSearch() {
        if (this.searchPanel.hasAttribute('hidden')) this.openSearch();
        else this.closeSearch();
      }
      openSearch() {
        this.searchPanel.removeAttribute('hidden');
        if (this.searchBackdrop) this.searchBackdrop.removeAttribute('hidden');
        this.searchToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        if (!this.searchInput.value.trim()) this.renderInitial();
        var input = this.searchInput;
        requestAnimationFrame(() => input.focus());
      }
      closeSearch() {
        if (!this.searchPanel || this.searchPanel.hasAttribute('hidden')) return;
        this.searchPanel.setAttribute('hidden', '');
        if (this.searchBackdrop) this.searchBackdrop.setAttribute('hidden', '');
        this.searchToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      renderInitial() {
        this.searchActive = -1;
        this.searchResults.innerHTML = '<p class="dcway-header__search-hint">Start typing to find camps, programs, blog posts and pages.</p>';
      }
      renderLoading() {
        this.searchResults.innerHTML = '<p class="dcway-header__search-loading">Searching…</p>';
      }
      money(v) {
        if (v == null || v === '') return '';
        var n = parseFloat(v);
        if (isNaN(n)) return '';
        return '$' + (n % 1 === 0 ? n.toFixed(0) : n.toFixed(2));
      }
      onSearchKey(e) {
        var items = this.searchResults.querySelectorAll('.dcway-header__search-result');
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          if (!items.length) return;
          e.preventDefault();
          this.searchActive += (e.key === 'ArrowDown' ? 1 : -1);
          if (this.searchActive < 0) this.searchActive = items.length - 1;
          if (this.searchActive >= items.length) this.searchActive = 0;
          items.forEach((el, i) => el.classList.toggle('is-active', i === this.searchActive));
          items[this.searchActive].scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter') {
          if (this.searchActive >= 0 && items[this.searchActive]) {
            e.preventDefault();
            window.location.href = items[this.searchActive].getAttribute('href');
          }
        }
      }
      runSearch(q) {
        var url = '{{ routes.predictive_search_url }}' + '.json?q=' + encodeURIComponent(q)
          + '&resources[type]=product,page,article&resources[limit]=6';
        var self = this;
        fetch(url, { headers: { 'Accept': 'application/json' } })
          .then((r) => r.json())
          .then((data) => self.renderResults(data, q))
          .catch(() => {});
      }
      renderResults(data, q) {
        this.searchActive = -1;
        var results = (data && data.resources && data.resources.results) || {};
        var groups = [
          { key: 'products', label: 'Programs & Camps' },
          { key: 'pages', label: 'Pages' },
          { key: 'articles', label: 'Blog' }
        ];
        var esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
        var self = this;
        var arrow = '<svg class="dcway-header__search-arrow" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M6.5 3.5L12 9l-5.5 5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        var html = '';
        var total = 0;
        groups.forEach((g) => {
          var items = results[g.key] || [];
          if (!items.length) return;
          html += '<div class="dcway-header__search-group"><p class="dcway-header__search-group-title">' + g.label + '</p>';
          items.forEach((item) => {
            total++;
            var img = (item.featured_image && item.featured_image.url) || item.image || '';
            var sub = '';
            if (g.key === 'products') {
              var bits = [];
              if (item.type) bits.push(esc(item.type));
              var price = self.money(item.price);
              var priceHtml = price ? '<span class="dcway-header__search-price">' + price + '</span>' : '';
              var subInner = bits.join(' · ');
              if (subInner && priceHtml) sub = '<span class="dcway-header__search-sub">' + subInner + ' · ' + priceHtml + '</span>';
              else if (priceHtml) sub = '<span class="dcway-header__search-sub">' + priceHtml + '</span>';
              else if (subInner) sub = '<span class="dcway-header__search-sub">' + subInner + '</span>';
            }
            html += '<a class="dcway-header__search-result" href="' + esc(item.url) + '">'
              + (img ? '<img src="' + esc(img) + '" alt="" loading="lazy">' : '<span class="dcway-header__search-result-noimg"></span>')
              + '<span class="dcway-header__search-info"><span class="dcway-header__search-rtitle">' + esc(item.title) + '</span>' + sub + '</span>'
              + arrow + '</a>';
          });
          html += '</div>';
        });
        if (!total) {
          html = '<p class="dcway-header__search-empty">No results for &ldquo;' + esc(q) + '&rdquo;. Press Enter to search everything.</p>';
        } else {
          html += '<a class="dcway-header__search-seeall" href="{{ routes.search_url }}?q=' + encodeURIComponent(q) + '">See all results for &ldquo;' + esc(q) + '&rdquo; &rarr;</a>';
        }
        this.searchResults.innerHTML = html;
      }
    });
  }
</script>

<style>
  :root {
    --dcway-header-h: 72px;
    --dcway-header-h-mobile: 60px;
  }

  /* Sticky must be applied to the Shopify section WRAPPER, not the inner element. */
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 100;
  }
  #shopify-section-{{ section.id }}.dcway-header-static {
    position: static;
  }
  .dcway-header {
    display: block;
    position: relative;
    background: var(--dcway-orange, #FF7200);
    color: #fff;
    width: 100%;
  }
  .dcway-header.is-scrolled {
    box-shadow: 0 2px 12px rgba(0,0,0,0.18);
  }

  .dcway-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(12px, 2vw, 28px);
    height: var(--dcway-header-h);
    padding: 0 clamp(16px, 3vw, 40px);
    max-width: 1480px;
    margin: 0 auto;
  }

  /* Hamburger (mobile only) */
  .dcway-header__hamburger {
    display: none;
    background: transparent;
    border: 0;
    color: #fff;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }
  .dcway-header__hamburger svg { width: 26px; height: 26px; }

  /* Logo */
  .dcway-header__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #fff;
    line-height: 0;
  }
  .dcway-header__logo-img {
    display: block;
    height: auto;
    width: auto;
    max-height: calc(var(--dcway-header-h) - 20px);
  }
  .dcway-header__logo-text {
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(22px, 2vw, 28px);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Desktop nav */
  .dcway-header__nav {
    justify-self: center;
  }
  .dcway-header__menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 32px);
  }
  .dcway-header__menu-item {
    position: relative;
  }
  .dcway-header__menu-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: #fff;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: clamp(15px, 1.05vw, 17px);
    letter-spacing: 0.01em;
    padding: 8px 0;
    transition: opacity 0.2s ease;
  }
  .dcway-header__menu-link:hover { opacity: 0.85; }
  .dcway-header__menu-item.is-active > .dcway-header__menu-link { opacity: 0.8; }
  .dcway-header__caret {
    width: 11px;
    height: 7px;
    transition: transform 0.2s ease;
  }
  .dcway-header__menu-item--has-children:hover .dcway-header__caret { transform: rotate(180deg); }

  /* Submenu (desktop) */
  .dcway-header__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    list-style: none;
    margin: 0;
    padding: 6px 0;
    background: #fff;
    color: #2C2C2C;
    box-shadow: 0 10px 28px rgba(0,0,0,0.18);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0.2s;
    z-index: 60;
  }
  .dcway-header__menu-item--has-children:hover .dcway-header__submenu,
  .dcway-header__menu-item--has-children:focus-within .dcway-header__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s;
  }
  .dcway-header__submenu-link {
    display: block;
    padding: 9px 18px;
    color: #2C2C2C;
    text-decoration: none;
    font-size: 15px;
    line-height: 1.3;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .dcway-header__submenu-link:hover {
    background: rgba(255,114,0,0.08);
    color: var(--dcway-orange, #FF7200);
  }

  /* Right actions */
  .dcway-header__actions {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1.4vw, 18px);
    justify-self: end;
  }
  .dcway-header__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .dcway-header__cart:hover { opacity: 0.85; }
  .dcway-header__cart svg { width: 22px; height: 22px; }
  .dcway-header__cart-count {
    position: absolute;
    top: -2px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    background: #fff;
    color: var(--dcway-orange, #FF7200);
    font-size: 11px;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    border-radius: 9px;
  }
  .dcway-header__cart-count[hidden] { display: none; }

  /* ---------- Predictive search ---------- */
  .dcway-header__search-toggle {
    background: transparent; border: 0; color: #fff; padding: 0;
    width: 40px; height: 40px; cursor: pointer; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.18s ease;
  }
  .dcway-header__search-toggle svg { width: 22px; height: 22px; }
  .dcway-header__search-toggle:hover { background: rgba(255,255,255,0.18); }

  .dcway-header__search-backdrop {
    position: absolute; top: 100%; left: 0; right: 0; height: 100vh;
    background: rgba(20,20,20,0.45); z-index: 110;
    opacity: 0; transition: opacity 0.2s ease;
  }
  .dcway-header__search-backdrop:not([hidden]) { opacity: 1; }

  .dcway-header__search {
    position: absolute; top: 100%; left: 0; right: 0;
    background: #fff; color: var(--dcway-dark, #2c2c2c);
    box-shadow: 0 18px 40px rgba(0,0,0,0.18);
    border-top: 3px solid var(--dcway-orange, #ff7200);
    z-index: 120;
  }
  .dcway-header__search:not([hidden]) { animation: dcwaySearchDrop 0.22s cubic-bezier(.22,.61,.36,1); }
  @keyframes dcwaySearchDrop {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .dcway-header__search-inner {
    max-width: 900px; margin: 0 auto;
    padding: 20px clamp(16px, 3vw, 32px) 24px;
  }
  .dcway-header__search-form { display: flex; align-items: center; gap: 14px; }
  .dcway-header__search-field {
    flex: 1 1 auto; min-width: 0;
    display: flex; align-items: center; gap: 12px;
    background: var(--dcway-muted-bg, #f2f2f2);
    border: 2px solid transparent;
    border-radius: var(--dcway-radius, 12px);
    padding: 0 14px; height: 52px;
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .dcway-header__search-field:focus-within {
    background: #fff; border-color: var(--dcway-orange, #ff7200);
  }
  .dcway-header__search-icon { width: 22px; height: 22px; color: var(--dcway-orange, #ff7200); flex: 0 0 auto; }
  .dcway-header__search-input {
    flex: 1 1 auto; min-width: 0; border: 0; outline: 0;
    font-size: 17px; background: transparent; color: inherit; height: 100%;
  }
  .dcway-header__search-input::-webkit-search-cancel-button { display: none; }
  .dcway-header__search-clear {
    background: rgba(0,0,0,0.08); border: 0; cursor: pointer; color: var(--dcway-dark, #2c2c2c);
    width: 26px; height: 26px; border-radius: 50%; flex: 0 0 auto;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .dcway-header__search-clear svg { width: 16px; height: 16px; }
  .dcway-header__search-clear[hidden] { display: none; }
  .dcway-header__search-close {
    background: transparent; border: 0; cursor: pointer; flex: 0 0 auto;
    color: var(--dcway-muted, #737373); font-weight: 700; font-size: 14px;
    text-transform: uppercase; letter-spacing: 0.04em; padding: 6px 8px;
  }
  .dcway-header__search-close:hover { color: var(--dcway-dark, #2c2c2c); }

  .dcway-header__search-results {
    margin-top: 18px; display: flex; flex-direction: column; gap: 20px;
    max-height: 64vh; overflow-y: auto;
  }
  .dcway-header__search-group-title {
    margin: 0 0 8px; font-size: 12px; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--dcway-muted, #737373); font-weight: 700;
  }
  .dcway-header__search-result {
    display: flex; align-items: center; gap: 14px; padding: 8px 10px;
    border-radius: var(--dcway-radius-sm, 8px); text-decoration: none;
    color: var(--dcway-dark, #2c2c2c); transition: background 0.14s ease;
  }
  .dcway-header__search-result:hover,
  .dcway-header__search-result.is-active {
    background: var(--dcway-muted-bg, #f2f2f2);
  }
  .dcway-header__search-result img,
  .dcway-header__search-result-noimg {
    width: 52px; height: 52px; border-radius: var(--dcway-radius-sm, 8px);
    object-fit: cover; flex: 0 0 auto; background: var(--dcway-muted-bg-2, #e5e5e5);
  }
  .dcway-header__search-info { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .dcway-header__search-rtitle {
    font-size: 15px; font-weight: 700; line-height: 1.25;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .dcway-header__search-sub { font-size: 13px; color: var(--dcway-muted, #737373); }
  .dcway-header__search-price { color: var(--dcway-orange, #ff7200); font-weight: 700; }
  .dcway-header__search-arrow { width: 16px; height: 16px; color: var(--dcway-muted, #737373); flex: 0 0 auto; opacity: 0; transition: opacity 0.14s ease; }
  .dcway-header__search-result:hover .dcway-header__search-arrow,
  .dcway-header__search-result.is-active .dcway-header__search-arrow { opacity: 1; }

  .dcway-header__search-seeall {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 4px; padding: 10px 4px;
    font-weight: 700; font-size: 14px; text-decoration: none;
    color: var(--dcway-orange, #ff7200);
  }
  .dcway-header__search-seeall:hover { color: var(--dcway-orange-hover, #e66700); }
  .dcway-header__search-empty,
  .dcway-header__search-hint,
  .dcway-header__search-loading {
    margin: 4px 0; color: var(--dcway-muted, #737373); font-size: 14px;
  }

  @media (max-width: 749px) {
    .dcway-header__search-close { display: none; }
    .dcway-header__search-inner { padding: 14px 16px 18px; }
  }

  .dcway-header__login {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    border: 2px solid #fff;
    background: transparent;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(14px, 1.05vw, 16px);
    letter-spacing: 0.02em;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }
  .dcway-header__login:hover {
    background: #fff;
    color: var(--dcway-orange, #FF7200);
  }

  /* Mobile drawer (closed by default) */
  .dcway-header__drawer {
    position: fixed;
    inset: var(--dcway-header-h-mobile) 0 0 0;
    background: var(--dcway-orange, #FF7200);
    z-index: 49;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s linear 0.25s;
  }
  .dcway-header__drawer[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s;
  }
  .dcway-header__drawer-inner {
    padding: 20px 24px 40px;
  }
  .dcway-header__drawer-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dcway-header__drawer-link,
  .dcway-header__drawer-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    border: 0;
    padding: 14px 0;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.18);
  }
  .dcway-header__drawer-toggle svg { width: 14px; height: 9px; transition: transform 0.2s ease; }
  .dcway-header__drawer-toggle[aria-expanded="true"] svg { transform: rotate(180deg); }
  .dcway-header__drawer-sub {
    list-style: none;
    margin: 0;
    padding: 4px 0 12px 16px;
  }
  .dcway-header__drawer-sub-link {
    display: block;
    padding: 8px 0;
    color: rgba(255,255,255,0.92);
    text-decoration: none;
    font-size: 15px;
    line-height: 1.35;
  }
  .dcway-header__drawer-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 24px;
    padding: 14px 24px;
    background: #fff;
    color: var(--dcway-orange, #FF7200);
    text-decoration: none;
    font-family: var(--font-heading-family), 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    width: 100%;
  }

  /* ---------- TABLET ---------- */
  @media (max-width: 989px) {
    .dcway-header__inner {
      grid-template-columns: auto 1fr auto;
      height: var(--dcway-header-h-mobile);
      gap: 12px;
    }
    .dcway-header__hamburger { display: inline-flex; }
    .dcway-header__nav { display: none; }
    .dcway-header__login { display: none; }
    .dcway-header__logo { justify-self: center; }
    .dcway-header__logo-img { max-height: calc(var(--dcway-header-h-mobile) - 14px); }
  }
</style>

{% schema %}
{
  "name": "Header (DC Way)",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (image picker)"
    },
    {
      "type": "url",
      "id": "logo_url",
      "label": "Logo URL (fallback)",
      "info": "Direct image URL. Used when no image picker logo is set."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo max width (px)",
      "min": 80,
      "max": 320,
      "step": 10,
      "default": 180
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky header",
      "default": true
    },
    {
      "type": "header",
      "content": "Account / cart"
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login button label",
      "default": "Login/Register"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account button label (logged in)",
      "default": "My Account"
    },
    {
      "type": "url",
      "id": "login_url",
      "label": "Login link (optional)",
      "info": "Defaults to /account/login when empty."
    },
    {
      "type": "header",
      "content": "Compat (do not change)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme (for cart-notification)",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "label": "Menu type (compat)",
      "options": [
        { "value": "dropdown", "label": "Dropdown" },
        { "value": "mega", "label": "Mega" }
      ],
      "default": "dropdown"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
