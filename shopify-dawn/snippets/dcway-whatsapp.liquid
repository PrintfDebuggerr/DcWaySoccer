{%- comment -%}
  Floating WhatsApp / chat button (task #32). Site-wide, admin-configurable via
  Theme settings → "DC Way — WhatsApp / Chat" (number, message, tooltip, side, mobile).
  Pure theme — no third-party app. Rendered once before </body> in theme.liquid.
{%- endcomment -%}

{%- liquid
  assign number = settings.dcway_whatsapp_number | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')'
  assign enabled = settings.dcway_whatsapp_enabled
-%}

{%- if enabled and number != blank -%}
  {%- assign wa_href = 'https://wa.me/' | append: number -%}
  {%- if settings.dcway_whatsapp_message != blank -%}
    {%- comment -%} Escape only the message, not the ?text= separators {%- endcomment -%}
    {%- assign msg = settings.dcway_whatsapp_message | url_param_escape -%}
    {%- assign wa_href = wa_href | append: '?text=' | append: msg -%}
  {%- endif -%}

  <a
    class="dcway-wa dcway-wa--{{ settings.dcway_whatsapp_position }}{% unless settings.dcway_whatsapp_show_mobile %} dcway-wa--desktop-only{% endunless %}"
    href="{{ wa_href }}"
    target="_blank"
    rel="noopener"
    aria-label="Chat with DC Way on WhatsApp"
  >
    <span class="dcway-wa__icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" width="30" height="30" focusable="false">
        <path fill="currentColor" d="M16.001 3.2C8.94 3.2 3.2 8.94 3.2 16c0 2.26.6 4.46 1.74 6.4L3.2 28.8l6.56-1.72A12.74 12.74 0 0 0 16 28.8C23.06 28.8 28.8 23.06 28.8 16S23.06 3.2 16.001 3.2zm0 23.04c-1.98 0-3.92-.53-5.61-1.53l-.4-.24-3.89 1.02 1.04-3.79-.26-.41A10.2 10.2 0 0 1 5.76 16c0-5.65 4.6-10.24 10.24-10.24S26.24 10.35 26.24 16s-4.6 10.24-10.24 10.24zm5.62-7.67c-.31-.16-1.82-.9-2.1-1-.28-.1-.49-.16-.69.16-.2.31-.79 1-.97 1.2-.18.2-.36.23-.67.08-.31-.16-1.3-.48-2.48-1.53-.92-.82-1.54-1.83-1.72-2.14-.18-.31-.02-.48.14-.63.14-.14.31-.36.47-.54.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.54-.08-.16-.69-1.67-.95-2.28-.25-.6-.5-.52-.69-.53l-.59-.01c-.2 0-.54.08-.82.39-.28.31-1.08 1.06-1.08 2.58s1.1 2.99 1.26 3.2c.16.21 2.18 3.33 5.29 4.67.74.32 1.31.51 1.76.65.74.24 1.41.2 1.94.12.59-.09 1.82-.74 2.08-1.46.26-.72.26-1.33.18-1.46-.08-.13-.28-.21-.59-.36z"/>
      </svg>
    </span>
    {%- if settings.dcway_whatsapp_tooltip != blank -%}
      <span class="dcway-wa__label">{{ settings.dcway_whatsapp_tooltip }}</span>
    {%- endif -%}
  </a>

  {%- style -%}
    .dcway-wa {
      position: fixed;
      bottom: 22px;
      z-index: 998;
      display: inline-flex;
      align-items: center;
      gap: 0;
      height: 56px;
      padding: 0;
      background: #25d366;
      color: #fff;
      border-radius: 999px;
      box-shadow: 0 6px 20px rgba(0,0,0,.22);
      text-decoration: none;
      transition: transform .18s ease, box-shadow .18s ease, padding .18s ease, gap .18s ease;
      overflow: hidden;
    }
    .dcway-wa--right { right: 22px; }
    .dcway-wa--left { left: 22px; }
    .dcway-wa__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      flex: 0 0 56px;
    }
    .dcway-wa__label {
      white-space: nowrap;
      font-weight: 700;
      font-size: 15px;
      max-width: 0;
      opacity: 0;
      transition: max-width .25s ease, opacity .2s ease, padding .25s ease;
      padding-right: 0;
    }
    .dcway-wa:hover,
    .dcway-wa:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 10px 26px rgba(0,0,0,.28);
    }
    @media (hover: hover) and (min-width: 750px) {
      .dcway-wa:hover .dcway-wa__label,
      .dcway-wa:focus-visible .dcway-wa__label {
        max-width: 200px;
        opacity: 1;
        padding-right: 20px;
      }
    }
    .dcway-wa--desktop-only { display: none; }
    @media (min-width: 750px) { .dcway-wa--desktop-only { display: inline-flex; } }
    @media (prefers-reduced-motion: reduce) { .dcway-wa { transition: none; } }
  {%- endstyle -%}
{%- endif -%}
