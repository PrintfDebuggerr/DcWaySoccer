    "faq": {
      "type": "collapsible-content",
      "blocks": {
        "q_offer": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What do we offer at Summer Camp?",
            "icon": "question_mark",
            "row_content": "<p>We offer weekly soccer camps for children Monday through Friday. We teach fundamental soccer skills in a fun, positive, non-competitive, and safe environment where children can grow, develop new skills, and stay active while having fun in the summer.</p>"
          }
        },
        "q_ages": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What ages can attend?",
            "icon": "question_mark",
            "row_content": "<p>Boys and girls ages 4–13. We split campers into age- and skill-appropriate groups. Please note that 4-year-old children must be potty trained and able to follow directions.</p>"
          }
        },
        "q_bring": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What should my child bring?",
            "icon": "question_mark",
            "row_content": "<p>Soccer cleats or sneakers, shin guards, a refillable water bottle, sunscreen, a hat, and a packed lunch. We provide soccer balls and all equipment.</p>"
          }
        },
        "q_options": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What are the camp options and pricing?",
            "icon": "question_mark",
            "row_content": "<p><strong>Full Week</strong> — 9:00 am to 3:00 pm.<br><strong>Extended Full Week</strong> — 9:00 am to 5:30 pm with before- and after-care available.<br>Exact pricing is listed on each camp page.</p>"
          }
        },
        "q_refund": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the refund and transfer policy?",
            "icon": "question_mark",
            "row_content": "<p>Cancellations made at least 14 days before the camp start date are eligible for a full refund less a processing fee. Within 14 days, we can transfer your spot to another week if availability allows. Reach out to us at <a href=\"/pages/contact\">our contact page</a> for details.</p>"
          }
        }
      },
